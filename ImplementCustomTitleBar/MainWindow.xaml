<Window x:Class="ImplementCustomTitleBar.MainWindow"
     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Custom Title Bar App" 
        Height="450" Width="800"

        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome 
            CaptionHeight="36"
            ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
            GlassFrameThickness="0,0,0,0"          
            CornerRadius="8"
            NonClientFrameEdges="None"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            Background="Black"
            CornerRadius="8"
            BorderBrush="BlanchedAlmond"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar - transparent container, but buttons are in a solid sub-layer -->
            <Border Grid.Row="0" 
                    Background="Transparent"  
                IsHitTestVisible="True">

                <DockPanel IsHitTestVisible="True"
                           shell:WindowChrome.IsHitTestVisibleInChrome="True"
                           MouseLeftButtonDown="DockPanel_MouseLeftButtonDown">
                    <!-- Left: title -->
                    <TextBlock DockPanel.Dock="Left" 
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="12,0"/>

                    <!-- Solid background for buttons only -->
                    <Border DockPanel.Dock="Right" 
                            Background="Gray" 
                            IsHitTestVisible="True">

                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right"
                                    IsHitTestVisible="True">

                            <Button x:Name="btnMinimize"
                                    Panel.ZIndex="100"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                    IsHitTestVisible="True"
                                    Focusable="True"
                                    Content="—"
                                    Click="btnMinimize_Click"
                                    Width="46" Height="36"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"
                                    FontSize="12"
                                    Padding="0"
                                    MouseEnter="WindowButton_MouseEnter"
                                    MouseLeave="WindowButton_MouseLeave" />

                            <Button x:Name="btnMaximizeRestore" 
                                Panel.ZIndex="100"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                IsHitTestVisible="True"
                                Focusable="True"
                                Content="□"
                                Click="btnMaximizeRestore_Click"
                                Width="46" Height="36"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                FontSize="12"
                                Padding="0"
                                MouseEnter="WindowButton_MouseEnter"
                                MouseLeave="WindowButton_MouseLeave" />

                        <Button x:Name="btnClose" 
                                Panel.ZIndex="100"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                IsHitTestVisible="True"
                                Focusable="True"
                                Content="×"
                                Click="btnClose_Click"
                                Width="46" Height="36"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                FontSize="14"
                                Padding="0"
                                MouseEnter="WindowButton_MouseEnter"
                                MouseLeave="WindowButton_MouseLeave"
                                />
                            
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Main content (e.g. a label to test) -->
            <DockPanel Grid.Row="1">
             <Label DockPanel.Dock="Top" Content="Main Content Area" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StatusBar DockPanel.Dock="Bottom" Height="25" VerticalAlignment="Bottom">
                    <StatusBarItem Content="Bottom Status Bar" />
                </StatusBar>
            </DockPanel>
        </Grid>
    </Border>
</Window>
    
