<Window x:Class="EFEntityEntryTesting.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EFEntityEntryTesting"
        xmlns:EF="clr-namespace:EFEntityEntryTesting.EF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <EF:DataManager x:Key="EFDataManager" />
    </Window.Resources>
    <DockPanel DataContext="{StaticResource EFDataManager}">
        <DataGrid DockPanel.Dock="Left" ItemsSource="{Binding Quotes}" AutoGenerateColumns="True" Width="250" />
        <DataGrid DockPanel.Dock="Right" ItemsSource="{Binding CategoryList}" AutoGenerateColumns="True" Width="250" />
    </DockPanel>
</Window>
