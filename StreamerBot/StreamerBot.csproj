<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Version>2.0.1.3</Version>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows7.0</TargetFramework>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<Nullable>disable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>
		<AssemblyName>TwineStreamerBot</AssemblyName>
		<Description>A chat, clip, live, follow bot for Twitch using the C# TwitchLib library. https://twitch.tv/WrithemTwine</Description>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/WrithemTwine/TwineChatBot</PackageProjectUrl>
		<RepositoryUrl>https://github.com/WrithemTwine/TwineChatBot</RepositoryUrl>
		<NeutralLanguage>en-US</NeutralLanguage>
		<PackageTags>Twitch, bot, twitchlib, streamer</PackageTags>
		<Copyright>2026</Copyright>
		<PackageReleaseNotes>Updated to Entity Framework Core</PackageReleaseNotes>
		<Authors>WrithemTwine</Authors>
		<Company>TwineStreamerBot</Company>
		<ApplicationIcon>img\TSB_Icon.ico</ApplicationIcon>
		<Configurations>Debug;Release;Release_Sqlite;Release_PostGre;Release_KNet;Release_Cosmos;Release_MySql;Release_SqlServer;Debug_ViewXAML;Release_PomeloMySql;Debug_EFEETesting;Update_Nuget_Only</Configurations>
	</PropertyGroup>

	<ItemGroup>
	  <None Remove="img\TSB_Icon.ico" />
	</ItemGroup>

	<ItemGroup>
	  <Page Remove="Culture\GUIMsgs.xaml" />
	  <Page Remove="Culture\GUI_HelpMsgs.xaml" />
	  <Page Remove="Culture\GUI_Msgs.xaml" />
	</ItemGroup>

	<ItemGroup>
	  <Resource Include="Culture\GUIMsgs.xaml" />
	  <Resource Include="Culture\GUI_HelpMsgs.xaml" />
	  <Resource Include="Culture\GUI_Msgs.xaml" />
	  <Resource Include="img\TSB_Icon.ico" />
	</ItemGroup>
	
	<!-- <ItemGroup>
	  <None Remove="img\BotStartupLogo.png" />
	</ItemGroup> -->

	<ItemGroup>
		<PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3719.77" />
	</ItemGroup>

	<PropertyGroup Label="Globals">
	  <WV2WinRTWrapWebViewTypes>True</WV2WinRTWrapWebViewTypes>
	</PropertyGroup>
	
	<PropertyGroup>
		<WebView2LoaderPreference>Dynamic</WebView2LoaderPreference>
		<StartupObject>StreamerBot.App</StartupObject>
		<PlatformTarget>x64</PlatformTarget>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release_Sqlite|AnyCPU'">
	  <Optimize>True</Optimize>
	  <DebugType>none</DebugType>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release_PostGre|AnyCPU'">
	  <Optimize>True</Optimize>
	  <DebugType>none</DebugType>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release_KNet|AnyCPU'">
	  <Optimize>True</Optimize>
	  <DebugType>none</DebugType>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release_Cosmos|AnyCPU'">
	  <Optimize>True</Optimize>
	  <DebugType>none</DebugType>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release_MySql|AnyCPU'">
	  <Optimize>True</Optimize>
	  <DebugType>none</DebugType>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release_PomeloMySql|AnyCPU'">
	  <Optimize>True</Optimize>
	  <DebugType>none</DebugType>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release_SqlServer|AnyCPU'">
	  <Optimize>True</Optimize>
	  <DebugType>none</DebugType>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
	  <DebugType>none</DebugType>
	</PropertyGroup>
	
	<ItemGroup>
	  <ProjectReference Include="..\StreamerBotLib\StreamerBotLib.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <SplashScreen Include="img\BotStartupLogo.png" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Properties\PublishProfiles\" />
	</ItemGroup>

</Project>
