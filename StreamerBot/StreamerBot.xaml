                          CanUserDeleteRows="True" 
                          RowEditEnding="DataGrid_RowEditEnding" 
                          ContextMenuOpening="DG_Edit_ContextMenuOpening">
                                                    <DataGrid.Columns>
                                                        <DataGridComboBoxColumn Header="{DynamicResource Data_UserData_Platform_Column}" 
                                                SelectedItemBinding="{Binding Platform}" 
                                                ItemsSource="{Binding Source={StaticResource EnumPlatform}}" />
                                                        <DataGridTextColumn Header="{DynamicResource Data_UserData_UserId_Column}" 
                                            Binding="{Binding UserId}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridTextColumn Header="{DynamicResource Data_UserData_UserName_Column}" 
                                            Binding="{Binding User.UserName}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridCheckBoxColumn Header="{DynamicResource Data_UserData_Follower_Column}" 
                                                Binding="{Binding User.Follower.IsFollower}" />
                                                        <DataGridTextColumn Header="{DynamicResource Data_AutoSO_Message_Column}" 
                                            Binding="{Binding Message}" Width="250" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" />
                                                    </DataGrid.Columns>
                                                    <DataGrid.GroupStyle>
                                                        <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                    </DataGrid.GroupStyle>
                                                </DataGrid>
                                            </Grid>
                                        </TabItem>

                                        <!-- Currency  -->
                                        <TabItem Header="{DynamicResource Data_Currency_SubHeader}" x:Name="TabItem_CurrencyAccrual">
                                            <TabControl>
                                                <TabItem Header="{DynamicResource Data_Currency_Data_SubHeader}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="65" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="400"/>
                                                            <ColumnDefinition Width="5"/>
                                                            <ColumnDefinition />
                                                        </Grid.ColumnDefinitions>

                                                        <Label Grid.Row="0" Grid.ColumnSpan="3">
                                                            <TextBlock Width="744" Text="{DynamicResource Data_Currency_Instructions}"/>
                                                        </Label>

                                                        <Button x:Name="Button_ClearCurrencyAccrlValues" Grid.Column="2" Height="20" Width="147" 
                        Content="{DynamicResource Data_Currency_ClearAllValues}" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Right" 
                        Click="Button_ClearCurrencyAccrlValues_Click" />

                                                        <DataGrid x:Name="DG_CurrencyType"
                          ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_CurrencyType_CVS}}"
                          PreviewKeyDown="DG_PreviewKeyDown_Click"
                          Grid.Row="1" Grid.Column="0" 
                          ContextMenuOpening="DG_Edit_ContextMenuOpening" 
                          CanUserDeleteRows="True" 
                          RowEditEnding="DataGrid_RowEditEnding">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="{DynamicResource Data_Currency_CurrencyName_Column}" 
                                            Binding="{Binding CurrencyName}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                                <DataGridTextColumn Header="{DynamicResource Data_Currency_AccrueAmt_Column}" 
                                            Binding="{Binding AccrueAmt, StringFormat=\{0:N0\}}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                                <DataGridTextColumn Header="{DynamicResource Data_Currency_Seconds_Column}" 
                                            Binding="{Binding Seconds, StringFormat=\{0:N0\}}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                                <DataGridTextColumn Header="{DynamicResource Data_Currency_MaxValue_Column}" 
                                            Binding="{Binding MaxValue, StringFormat=\{0:N0\}}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                            </DataGrid.Columns>
                                                            <DataGrid.GroupStyle>
                                                                <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                            </DataGrid.GroupStyle>
                                                        </DataGrid>

                                                        <DataGrid x:Name="DG_Currency" 
                          ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_Currency_CVS}}" 
                          PreviewKeyDown="DG_PreviewKeyDown_Click"
                          Grid.Row="1" Grid.Column="2" 
                          RowEditEnding="DataGrid_RowEditEnding" 
                          ContextMenuOpening="DG_Edit_ContextMenuOpening">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="{DynamicResource Data_UserData_UserId_Column}" 
                                            Binding="{Binding UserId}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                                <DataGridTextColumn Header="{DynamicResource Data_UserData_UserName_Column}" 
                                            Binding="{Binding User.UserName}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                                <DataGridCheckBoxColumn Header="{DynamicResource Data_UserData_Follower_Column}" 
                                                Binding="{Binding User.Follower.IsFollower}" />
                                                                <DataGridTextColumn Header="{DynamicResource Data_UserData_WatchTime_Column}" 
                                            Binding="{Binding User.UserStats.WatchTime}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" />
                                                                <DataGridTextColumn Header="{DynamicResource Data_Currency_Value_Column}" 
                                            Binding="{Binding Value, StringFormat=\{0:N0\}}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                            </DataGrid.Columns>
                                                            <DataGrid.GroupStyle>
                                                                <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                            </DataGrid.GroupStyle>
                                                        </DataGrid>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="{DynamicResource Data_Currency_Games_SubHeader}">
                                                    <WrapPanel DataContext="{Binding Source={x:Static s:Settings.Default}}">
                                                        <GroupBox Header="{DynamicResource Data_Currency_Blackjack_Header}" Padding="5">
                                                            <GroupBox.Resources>
                                                                <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                    <Setter Property="Height" Value="19" />
                                                                    <Setter Property="Width" Value="30" />
                                                                </Style>
                                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                    <Setter Property="Width" Value="100" />
                                                                </Style>
                                                                <Style TargetType="{x:Type StackPanel}">
                                                                    <Setter Property="Margin" Value="0,2" />
                                                                </Style>
                                                            </GroupBox.Resources>
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{DynamicResource Data_Currency_Blackjack_HouseStands}"/>
                                                                    <TextBox Text="{Binding GameBlackJackHouseStands}" />
                                                                </StackPanel>
                                                                <TextBlock />
                                                                <TextBlock TextDecorations="Underline" Text="{DynamicResource Data_Currency_Blackjack_Payouts}"/>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{DynamicResource Data_Currency_Blackjack_Dealt21}"/>
                                                                    <TextBox Text="{Binding GameBlackJackPayoutDealt21}" />
                                                                    <TextBlock Width="20">%</TextBlock>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{DynamicResource Data_Currency_Blackjack_Reaches21}"/>
                                                                    <TextBox Text="{Binding GameBlackJackPayoutReach21}" />
                                                                    <TextBlock Width="20">%</TextBlock>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{DynamicResource Data_Currency_Blackjack_Under21Stop}"/>
                                                                    <TextBox Text="{Binding GameBlackJackPayoutUnder21}" />
                                                                    <TextBlock Width="20">%</TextBlock>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Vertical">
                                                                    <TextBlock Width="180" Text="{DynamicResource Data_Currency_Blackjack_PayoutMessage}"/>
                                                                    <TextBox Width="180" Text="{Binding GameBlackJackPayoutMessage}" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </GroupBox>
                                                    </WrapPanel>
                                                </TabItem>
                                            </TabControl>
                                        </TabItem>

                                        <!-- Giveaways -->
                                        <TabItem Header="{DynamicResource Data_Giveaways_SubHeader}" x:Name="TabItem_Giveaways" 
                 Loaded="TabItem_Giveaways_Loaded">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="50" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="250*" />
                                                    <ColumnDefinition Width="500" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="{DynamicResource Data_Giveaways_SetupNote}"/>

                                                <DockPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" 
                           DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}">
                                                    <DockPanel.Resources>
                                                        <Style TargetType="{x:Type Label}" BasedOn="{StaticResource {x:Type Label}}">
                                                            <Setter Property="Width" Value="180" />
                                                        </Style>
                                                        <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Setter Property="Width" Value="250"/>
                                                            <Setter Property="Height" Value="18" />
                                                        </Style>
                                                    </DockPanel.Resources>

                                                    <GroupBox DockPanel.Dock="Top" 
                              Header="{DynamicResource Data_Giveaways_Condition_Header}" 
                              Width="Auto" VerticalAlignment="Top">
                                                        <GroupBox.ToolTip>
                                                            <TextBlock Text="{DynamicResource Data_Giveaways_Condition_Tooltip}"/>
                                                        </GroupBox.ToolTip>
                                                        <StackPanel>
                                                            <RadioButton x:Name="RadioButton_GiveawayCommand" 
                                         VerticalContentAlignment="Center">
                                                                <RadioButton.ToolTip>
                                                                    <TextBlock Text="{DynamicResource Data_Giveaways_Command_Tooltip}"/>
                                                                </RadioButton.ToolTip>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Label Width="100" Content="{DynamicResource Data_Giveaways_Command_Label}"/>
                                                                    <ComboBox x:Name="ComboBox_Giveaway_Coms" MinWidth="200" 
                                              DataContext="{Binding Mode=OneWay, Source={StaticResource DataViews}}" 
                                              ItemsSource="{Binding CommandCollection, Mode=OneWay}" 
                                              PreviewMouseLeftButtonDown="ComboBox_Giveaway_PreviewMouseLeftButtonDown" 
                                              DropDownClosed="ComboBox_Giveaway_DropDownClosed" />
                                                                </StackPanel>
                                                            </RadioButton>

                                                            <RadioButton x:Name="RadioButton_GiveawayCustomRewards" 
                                         VerticalContentAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <WrapPanel Orientation="Horizontal">
                                                                        <Label Width="100" Content="{DynamicResource Data_Giveaways_ChannelPoints_Label}"/>
                                                                        <Button x:Name="Button_Giveaway_RefreshChannelPoints" 
                                                Margin="5,0" Height="21" 
                                                Padding="5,2" 
                                                Content="{DynamicResource Common_Refresh}" 
                                                Click="Button_RefreshChannelPoints_Click" />
                                                                    </WrapPanel>
                                                                    <ComboBox x:Name="ComboBox_Giveaway_ChanPts" 
                                              MinWidth="200" 
                                              PreviewMouseLeftButtonDown="ComboBox_Giveaway_PreviewMouseLeftButtonDown" 
                                              DropDownClosed="ComboBox_Giveaway_DropDownClosed" />
                                                                </StackPanel>
                                                            </RadioButton>
                                                        </StackPanel>
                                                    </GroupBox>

                                                    <StackPanel DockPanel.Dock="Top" Margin="5" Orientation="Horizontal">
                                                        <CheckBox IsChecked="{Binding GiveawayMultiUser}">
                                                            <Label Content="{DynamicResource Data_Giveaways_MultiEntry}"/>
                                                        </CheckBox>
                                                        <Label Margin="50,0,0,0" VerticalAlignment="Center" 
                               Width="Auto" 
                               Content="{DynamicResource Data_Giveaways_MaxEntries_Label}"/>
                                                        <TextBox Width="40" 
                                 Text="{Binding GiveawayMaxEntries}" 
                                 ToolTip="{DynamicResource Data_Giveaways_MaxEntries_Tooltip}" 
                                 HorizontalContentAlignment="Center" 
                                 PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"/>
                                                    </StackPanel>

                                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                                                        <StackPanel.Resources>
                                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                                <Setter Property="Padding" Value="5,0" />
                                                                <Setter Property="Margin" Value="5,3"/>
                                                            </Style>
                                                        </StackPanel.Resources>
                                                        <Button x:Name="Button_GiveawayBegin" 
                                Content="{DynamicResource Data_Giveaways_Begin}" 
                                Click="Button_GiveawayBegin_Click" IsEnabled="False">
                                                            <Button.ToolTip>
                                                                <TextBlock Text="{DynamicResource Data_Giveaways_Begin_Tooltip}"/>
                                                            </Button.ToolTip>
                                                        </Button>
                                                        <Button x:Name="Button_GiveawayEnd" 
                                Content="{DynamicResource Data_Giveaways_End}" 
                                Click="Button_GiveawayEnd_Click" 
                                IsEnabled="False" />
                                                        <Button x:Name="Button_GiveawayPickWinner" 
                                Content="{DynamicResource Data_Giveaways_PickWinner}" 
                                Click="Button_GiveawayPickWinner_Click" IsEnabled="False" />
                                                    </StackPanel>

                                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                                        <Label Content="{DynamicResource Data_Giveaways_Winners_Label}"/>
                                                        <TextBox Width="30" HorizontalContentAlignment="Center" 
                                 Text="{Binding GiveawayCount, Mode=TwoWay}" 
                                 PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll">
                                                            <TextBox.ToolTip>
                                                                <TextBlock Text="{DynamicResource Data_Giveaways_Winners_Tooltip}"/>
                                                            </TextBox.ToolTip>
                                                        </TextBox>
                                                    </StackPanel>

                                                    <Border DockPanel.Dock="Top" Margin="0,3" 
                            BorderBrush="{StaticResource LightBackground}" 
                            BorderThickness="1.5">
                                                        <DockPanel>
                                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                                                                <Label HorizontalAlignment="Left" 
                                       Content="{DynamicResource Data_Giveaways_StartMessage_Label}"/>
                                                                <CheckBox HorizontalAlignment="Left" VerticalAlignment="Top"
                                          IsChecked="{Binding GiveawayAnnounceBegMsg}">
                                                                    <TextBlock Text="{DynamicResource Data_Giveaways_Announce}"/>
                                                                </CheckBox>
                                                            </StackPanel>
                                                            <TextBox DockPanel.Dock="Top"
                                     Width="Auto"
                                     Height="Auto"
                                     HorizontalAlignment="Stretch"
                                     Text="{Binding GiveawayBegMsg, Mode=TwoWay}"
                                     PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"
                                     TextWrapping="Wrap"/>
                                                        </DockPanel>
                                                    </Border>

                                                    <Border DockPanel.Dock="Top" Margin="0,3" 
                            BorderBrush="{StaticResource LightBackground}" 
                            BorderThickness="1.5">
                                                        <DockPanel>
                                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                                                                <Label HorizontalAlignment="Left" 
                                       Content="{DynamicResource Data_Giveaways_EndMessage_Label}"/>
                                                                <CheckBox HorizontalAlignment="Left" VerticalAlignment="Top"
                                          IsChecked="{Binding GiveawayAnnounceEndMsg}">
                                                                    <TextBlock Text="{DynamicResource Data_Giveaways_Announce}"/>
                                                                </CheckBox>
                                                            </StackPanel>
                                                            <TextBox DockPanel.Dock="Top"
                                     Width="Auto"
                                     Height="Auto"
                                     HorizontalAlignment="Stretch"
                                     Text="{Binding GiveawayEndMsg, Mode=TwoWay}"
                                     PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"
                                     TextWrapping="Wrap"/>
                                                        </DockPanel>
                                                    </Border>

                                                    <Border DockPanel.Dock="Top" Margin="0,3" 
                            BorderBrush="{StaticResource LightBackground}" 
                            BorderThickness="1.5">
                                                        <DockPanel>
                                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                                                                <Label HorizontalAlignment="Left" 
                                       Content="{DynamicResource Data_Giveaways_WinnerMessage_Label}"/>
                                                                <CheckBox HorizontalAlignment="Left" VerticalAlignment="Top"
                                          IsChecked="{Binding GiveawayAnnounceWinMsg}">
                                                                    <TextBlock Text="{DynamicResource Data_Giveaways_Announce}"/>
                                                                </CheckBox>
                                                            </StackPanel>
                                                            <TextBox DockPanel.Dock="Top"
                                                                     Width="Auto"
                                                                     Height="Auto"
                                                                     HorizontalAlignment="Stretch"
                                                                     Text="{Binding GiveawayWinMsg, Mode=TwoWay}"
                                                                     PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"
                                                                     TextWrapping="Wrap"/>
                                                        </DockPanel>
                                                    </Border>

                                                    <StackPanel DockPanel.Dock="Top" Margin="0,10,0,2" 
                                Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Label Content="{DynamicResource Data_Giveaways_CurrentEntrants_Label}"/>
                                                        <Label Width="Auto" 
                               DataContext="{Binding Mode=OneWay, Source={StaticResource DataViews}}" 
                               Content="{Binding GiveawayCollection.Count, Mode=OneWay}"/>
                                                    </StackPanel>

                                                    <ListView DockPanel.Dock="Top" x:Name="listView" Width="300" 
                              DataContext="{Binding Mode=OneWay, Source={StaticResource DataViews}}"
                              ItemsSource="{Binding GiveawayCollection}">
                                                        <ListView.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding EntryNumber}" Width="50"/>
                                                                    <TextBlock Text="{Binding UserName}" Width="200"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ListView.ItemTemplate>
                                                    </ListView>
                                                </DockPanel>

                                                <TextBlock Grid.Row="0" Grid.Column="1" 
                           Text="{DynamicResource Data_Giveaways_ResultsNote}"/>

                                                <DataGrid x:Name="DG_User_Giveaway" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" 
                          ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_GiveawayUserData_CVS}}" 
                          PreviewKeyDown="DG_PreviewKeyDown_Click"
                          IsReadOnly="False" CanUserDeleteRows="True" 
                          RowEditEnding="DataGrid_RowEditEnding" 
                          ContextMenuOpening="DG_Edit_ContextMenuOpening">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="{DynamicResource Data_UserData_Platform_Column}" 
                                            Binding="{Binding Platform}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridTemplateColumn Header="{DynamicResource Data_Giveaways_DateTime_Column}" 
                                                SortMemberPath="DateTime" 
                                                CellTemplate="{StaticResource DateGiveawayTemplate}" 
                                                CellEditingTemplate="{StaticResource EditDateGiveawayTemplate}" />
                                                        <DataGridTextColumn Header="{DynamicResource Data_UserData_UserId_Column}" 
                                            Binding="{Binding UserId}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridTextColumn Header="{DynamicResource Data_UserData_UserName_Column}" 
                                            Binding="{Binding User.UserName}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridCheckBoxColumn Header="{DynamicResource Data_UserData_Follower_Column}" 
                                                Binding="{Binding User.Follower.IsFollower}" />
                                                        <DataGridTextColumn Header="{DynamicResource Data_UserData_WatchTime_Column}" 
                                            Binding="{Binding User.UserStats.WatchTime}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" />
                                                    </DataGrid.Columns>
                                                    <DataGrid.GroupStyle>
                                                        <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                    </DataGrid.GroupStyle>
                                                </DataGrid>
                                            </Grid>
                                        </TabItem>

                                        <!-- Quotes tab -->
                                        <TabItem Header="{DynamicResource Data_Quotes_SubHeader}">
                                            <Grid>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Top" 
                       Text="{DynamicResource Data_Quotes_Instructions}"/>

                                                    <DataGrid x:Name="DG_User_Quotes" 
                      ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_Quotes_CVS}}" 
                      PreviewKeyDown="DG_PreviewKeyDown_Click"
                      IsReadOnly="False"  
                      CanUserDeleteRows="True" 
                      ContextMenuOpening="DG_Edit_ContextMenuOpening"
                      RowEditEnding="DataGrid_RowEditEnding">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="{DynamicResource Data_Quotes_Number_Column}" 
                                        Binding="{Binding Number}" 
                                        EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                            <DataGridTextColumn Header="{DynamicResource Data_Quotes_Quote_Column}" 
                                        Binding="{Binding Quote}" 
                                        EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        </DataGrid.Columns>
                                                        <DataGrid.GroupStyle>
                                                            <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                        </DataGrid.GroupStyle>
                                                    </DataGrid>
                                                </DockPanel>
                                            </Grid>
                                        </TabItem>
                                    </TabControl>
                                </TabItem>

                                <!-- System Events sub-tab -->
                                <TabItem Header="{DynamicResource Data_SystemEvents_SubHeader}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="70" />
                                            <RowDefinition Height="100*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0*" />
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Margin="5,5,5,5" Grid.ColumnSpan="2">
                                            <TextBlock Text="{DynamicResource Data_SystemEvents_Instructions}"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button x:Name="Button_SystemEvents_Enabled" Width="80" Margin="10,0" 
                        Content="{DynamicResource Common_EnableAll}" 
                        Click="Button_SystemEvents_Click"/>
                                                <Button x:Name="Button_SystemEvents_Disabled" Width="80" 
                        Content="{DynamicResource Common_DisableAll}" 
                        Click="Button_SystemEvents_Click" />
                                            </StackPanel>
                                        </StackPanel>

                                        <DataGrid x:Name="DG_CommonMsgs" 
                  ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_ChannelEvents_CVS}}"  
                  Grid.Row="1" Grid.Column="1"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  ContextMenuOpening="DG_Edit_ContextMenuOpening" 
                  PreviewKeyDown="DG_PreviewKeyDown_Click"
                  RowEditEnding="DataGrid_RowEditEnding">
                                            <DataGrid.ToolTip>
                                                <TextBlock TextWrapping="Wrap" Width="500" 
                           Text="{DynamicResource Data_SystemEvents_Tooltip}"/>
                                            </DataGrid.ToolTip>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="{DynamicResource Data_SystemEvents_Name_Column}" 
                                    Binding="{Binding Name}" IsReadOnly="True" 
                                    EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                <DataGridCheckBoxColumn Header="{DynamicResource Common_Enabled}" 
                                        Binding="{Binding IsEnabled}" />
                                                <DataGridCheckBoxColumn Header="{DynamicResource Data_SystemEvents_AddMe_Column}" 
                                        Binding="{Binding AddMe}" />
                                                <DataGridCheckBoxColumn Header="{DynamicResource Data_SystemEvents_Announce_Column}" 
                                        Binding="{Binding Announce}" />
                                                <DataGridTextColumn Header="{DynamicResource Data_SystemEvents_SendMsg_Column}" 
                                    Binding="{Binding RepeatMsg}" 
                                    EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                <DataGridTextColumn Header="{DynamicResource Data_SystemEvents_Message_Column}" 
                                    Binding="{Binding Message}" Width="250" 
                                    EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                <DataGridTextColumn Header="{DynamicResource Data_SystemEvents_Variables_Column}" 
                                    Binding="{Binding Commands}" IsReadOnly="True" 
                                    EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                            </DataGrid.Columns>
                                            <DataGrid.GroupStyle>
                                                <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                            </DataGrid.GroupStyle>
                                        </DataGrid>
                                    </Grid>
                                </TabItem>

                                <!-- Commands sub-tab (with inner TabControl) -->
                                <TabItem Header="{DynamicResource Data_Commands_SubHeader}">
                                    <TabControl>
                                        <!-- Help inner tab -->
                                        <TabItem Header="{DynamicResource Data_Commands_Help_SubHeader}">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Text="{DynamicResource Data_Commands_Help_BuiltInNote}"/>
                                                <Rectangle Width="800" Stretch="Fill" Height="1" />
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <StackPanel Orientation="Vertical">
                                                        <Label Content="{DynamicResource Data_Commands_ViewerTypes_Label}"/>
                                                        <ListBox Width="100" HorizontalAlignment="Left"
                                 ItemsSource="{Binding Mode=OneWay, Source={StaticResource EnumViewerTypes}}" 
