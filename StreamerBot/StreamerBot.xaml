<Window x:Class="StreamerBot.StreamerBotWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    xmlns:local="clr-namespace:StreamerBot"
    xmlns:GUI="clr-namespace:StreamerBotLib.GUI;assembly=StreamerBotLib"
    xmlns:s="clr-namespace:StreamerBotLib.Properties;assembly=StreamerBotLib"
    xmlns:StaticLib="clr-namespace:StreamerBotLib.Static;assembly=StreamerBotLib"
    xmlns:Converters="clr-namespace:StreamerBotLib.DataSQL.Models.Converters;assembly=StreamerBotLib" 
   
    mc:Ignorable="d" 
    Title="{DynamicResource Window_Title}"
    Top="{Binding GUITop, Mode=TwoWay, Source={x:Static s:Settings.Default}}"
    Left="{Binding GUILeft, Mode=TwoWay, Source={x:Static s:Settings.Default}}"
    Height="{Binding GUIHeight, Mode=TwoWay, Source={x:Static s:Settings.Default}}" 
    Width="{Binding GUIWidth, Mode=TwoWay, Source={x:Static s:Settings.Default}}"
    MinWidth="600" MinHeight="800"
    Loaded="Window_Loaded" Closing="OnWindowClosing" UseLayoutRounding="True" SnapsToDevicePixels="True"
    Icon="/img/TSB_Icon.ico"
    WindowStyle="None"
    AllowsTransparency="False"
    Background="Transparent"
    ResizeMode="CanResizeWithGrip"
>

    <Window.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
            </ResourceDictionary.MergedDictionaries>

            <GUI:GUITwitchBots x:Name="TwitchBot" x:Key="TwitchBot" />
            <GUI:GUIAppStats x:Name="AppStats" x:Key="AppStats" />
            <GUI:GUIAppServices x:Name="AppServices" x:Key="AppServices" />
            <local:DebugFlags x:Name="DebugFlags" x:Key="DebugFlags" />

            <ContextMenu x:Key="DataGrid_ContextMenu" x:Name="DataGrid_ContextMenu">
                <MenuItem x:Name="DataGridContextMenu_AddItem"  
                          Header="{DynamicResource Common_Add}" Click="MenuItem_AddClick" />
                <MenuItem x:Name="DataGridContextMenu_DeleteItems" 
                          Header="Delete Selected Row(s)" Click="MenuItem_DeleteClick" 
                          ToolTip="Delete 1 or more rows, not for preset tables. No warning messages."/>
                <Separator x:Name="DataGridContextMenu_Separator1" />
                <MenuItem x:Name="DataGridContextMenu_AutoShout" 
                          Header="Add User to AutoShout list" ToolTip="Does not Duplicate" 
                          Visibility="Collapsed" Click="MenuItem_AutoShoutClick"/>
                <MenuItem x:Name="DataGridContextMenu_LiveMonitor" 
                          Header="Add User to LiveMonitor list" 
                          ToolTip="Does not Duplicate, 100 max" Visibility="Collapsed" 
                          Click="MenuItem_LiveMonitorClick"/>
                <Separator x:Name="DataGridContextMenu_Separator2" />
                <MenuItem x:Name="DataGridContextMenu_EnableItems" 
                          Header="Enable Selected Row(s)" Click="DataGridContextMenu_EnableItems_Click" />
                <MenuItem x:Name="DataGridContextMenu_DisableItems" 
                          Header="Disable Selected Row(s)" Click="DataGridContextMenu_DisableItems_Click" />
            </ContextMenu>
            <ContextMenu x:Key="DataGrid_LearnMsgsContextMenu" x:Name="DataGrid_LearnMsgsContextMenu" />

            <Style TargetType="{x:Type DataGrid}" BasedOn="{StaticResource {x:Type DataGrid}}">
                <Setter Property="ContextMenu" Value="{DynamicResource DataGrid_ContextMenu}"/>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="36"
            ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}"
            GlassFrameThickness="0,0,0,0"          
            CornerRadius="8"
            NonClientFrameEdges="None"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            Background="{DynamicResource FullBackground}"
            CornerRadius="8"
            BorderBrush="{DynamicResource PartBackground}"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" 
                    Background="Transparent"  
                    IsHitTestVisible="True">

                <DockPanel IsHitTestVisible="True"
                           WindowChrome.IsHitTestVisibleInChrome="True"
                           Background="{DynamicResource FullBackground}"
                           MouseLeftButtonDown="DockPanel_MouseLeftButtonDown"
                           LastChildFill="True">
                    <Image Source="/img/TSB_Icon.ico" Width="20" Height="20" Margin="0,0,8,0"/>

                    <TextBlock DockPanel.Dock="Left" 
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                               VerticalAlignment="Center"
                               Margin="8,0"/>

                    <Border DockPanel.Dock="Right" 
                            Background="{DynamicResource FullBackground}" 
                            IsHitTestVisible="True">

                        <!--<StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right"
                                    IsHitTestVisible="True">
                            <StackPanel.Resources>
                                <Style x:Key="BaseWindowButtonStyle" TargetType="{x:Type Button}">
                                    <Setter Property="Height" Value="28" />
                                    <Setter Property="Width" Value="40" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Focusable" Value="True" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                </Style>
                                <Style x:Key="WindowButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource BaseWindowButtonStyle}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#99CCCCFF" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style x:Key="WindowButtonStyleClose" TargetType="{x:Type Button}" BasedOn="{StaticResource BaseWindowButtonStyle}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#33FF4D4D" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Resources>

                            <Button x:Name="btnMinimize"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Content="—" Click="btnMinimize_Click"
                                    FontSize="12"
                                    Style="{StaticResource WindowButtonStyle}" />

                            <Button x:Name="btnMaximizeRestore" 
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Content="□" Click="btnMaximizeRestore_Click"
                                    FontSize="16" Padding="0,0,0,5"
                                    Style="{StaticResource WindowButtonStyle}" />

                            <Button x:Name="btnClose" 
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Content="x" Click="btnClose_Click"
                                    FontSize="14" Padding="0,0,0,3"
                                    Style="{StaticResource WindowButtonStyleClose}" />
                        </StackPanel>-->


                        <StackPanel Orientation="Horizontal" 
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,8,0">

                            <StackPanel.Resources>

                                <!-- Common base template -->
                                <ControlTemplate x:Key="CaptionButtonTemplate" TargetType="Button">
                                    <Border x:Name="bd"
                                        Background="Transparent"
                                        CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#20CCCCFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#66AAAAAA"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>

                                <!-- Close variant -->
                                <ControlTemplate x:Key="CaptionCloseButtonTemplate" TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="Transparent"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E51400"/>
                                            <!-- or #F04747 etc -->
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#B91C1C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>

                            </StackPanel.Resources>

                            <!-- Minimize / Maximize / Close buttons – polished version -->

                            <Button x:Name="btnMinimize"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Height="32" Width="46"
                                Margin="0,0,4,0"
                                Padding="0"
                                Template="{StaticResource CaptionButtonTemplate}"
                                Click="btnMinimize_Click">

                                <Path Data="M 0,0 L 10,0"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Button>

                            <Button x:Name="btnMaximizeRestore"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Content="□"
                                FontSize="14"
                                Template="{StaticResource CaptionButtonTemplate}"
                                Click="btnMaximizeRestore_Click"
                                Height="28" Width="40" />
                            
                            <!-- For close button – nicer × symbol -->
                            <Button x:Name="btnClose"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Height="32" Width="46"
                                    Margin="0"
                                    Padding="0"
                                    Template="{StaticResource CaptionCloseButtonTemplate}"
                                    Click="btnClose_Click">

                                <Path Data="M 0,0 L 10,10 M 10,0 L 0,10"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Button>

                        </StackPanel>

                    </Border>
                </DockPanel>
            </Border>

            <!-- Main Content -->
            <DockPanel Grid.Row="1">
                <!-- Status bars - auth failure warnings -->
                <StatusBar DockPanel.Dock="Bottom" Visibility="Collapsed" x:Name="StatusBar_TwitchAuth_BotAuthCodeInvalid">
                    <StatusBarItem Padding="0" Margin="0">
                        <TextBlock Foreground="{DynamicResource BrightStop}" 
                   Text="{DynamicResource Auth_BotTokenFailed}" 
                   TextWrapping="Wrap"/>
                    </StatusBarItem>
                </StatusBar>

                <StatusBar DockPanel.Dock="Bottom" Visibility="Collapsed" x:Name="StatusBar_TwitchAuth_NoScopesAuthCodeInvalid">
                    <StatusBarItem Padding="0" Margin="0">
                        <TextBlock Foreground="{DynamicResource BrightStop}" 
                   Text="{DynamicResource Auth_NoScopesTokenFailed}" 
                   TextWrapping="Wrap"/>
                    </StatusBarItem>
                </StatusBar>

                <StatusBar DockPanel.Dock="Bottom" Visibility="Collapsed" x:Name="StatusBar_TwitchAuth_StreamerAuthCodeInvalid">
                    <StatusBarItem Padding="0" Margin="0">
                        <TextBlock Foreground="{DynamicResource BrightStop}" 
                   Text="{DynamicResource Auth_StreamerTokenFailed}" 
                   TextWrapping="Wrap"/>
                    </StatusBarItem>
                </StatusBar>

                <!-- Main status bar (always visible) -->
                <StatusBar DockPanel.Dock="Bottom" Height="55" DataContext="{Binding Source={StaticResource DataViews}, Mode=OneWay}">
                    <StatusBar.Resources>
                        <Style TargetType="{x:Type StackPanel}">
                            <Setter Property="Orientation" Value="Horizontal" />
                        </Style>
                    </StatusBar.Resources>

                    <StatusBarItem>
                        <Grid>
                            <StackPanel x:Name="StatusBarItem_NewStableVersion" Height="35" Panel.ZIndex="5" Visibility="Collapsed">

                                <wv2:WebView2 x:Name="WebView2_GitHub_StableVersion" 
                              Visibility="Collapsed" 
                              DataContext="" 
                              Source="{Binding Mode=OneWay, Source={x:Static StaticLib:OptionFlags.GitHubStableLink}}" 
                              NavigationCompleted="WebView2_GitHub_StableVersion_NavigationCompleted"/>

                                <TextBlock 
                                    FontWeight="ExtraBold"
                                    Foreground="{DynamicResource BrightGo}" 
                                    Text="{DynamicResource Status_NewReleaseAvailable}" 
                                    TextWrapping="Wrap" Width="90" 
                                    TextAlignment="Center" >
                                    <TextBlock.ToolTip>
                                        <TextBlock Text="{DynamicResource Tooltip_NewReleaseAvailable}"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>

                            </StackPanel>

                            <StackPanel Orientation="Vertical" Panel.ZIndex="1">
                                <Label x:Name="StatusBarItem_BetaLabel" 
                       HorizontalContentAlignment="Center" Padding="0" 
                       Visibility="Collapsed"
                       FontSize="16" FontWeight="DemiBold">
                                    <TextBlock Foreground="{DynamicResource LabelBeta}">Beta</TextBlock>
                                </Label>
                                <Label x:Name="StatusBar_Label_Version" Content="Version Label" Padding="0"/>
                            </StackPanel>
                        </Grid>
                    </StatusBarItem>

                    <StatusBarItem>
                        <StackPanel>
                            <Label Visibility="Visible" x:Name="Label_StreamStatusOff"
                   BorderThickness="3" HorizontalContentAlignment="Center"
                   FontWeight="ExtraBold"
                   Width="120"
                   BorderBrush="{DynamicResource BrightStop}">
                                <TextBlock Foreground="{DynamicResource BrightStop}" 
                           Text="{DynamicResource Status_StreamOffline}"/>
                            </Label>
                            <Label Visibility="Collapsed" x:Name="Label_StreamStatusOn"
                   BorderThickness="3" HorizontalContentAlignment="Center"
                   FontWeight="ExtraBold"
                   Width="120"
                   BorderBrush="{DynamicResource BrightGo}">
                                <TextBlock Foreground="{DynamicResource BrightGo}" 
                           Text="{DynamicResource Status_StreamOnline}"/>
                            </Label>
                        </StackPanel>
                    </StatusBarItem>

                    <Separator />

                    <StatusBarItem>
                        <StackPanel Orientation="Vertical">
                            <Label Padding="3,0" HorizontalAlignment="Center" 
                                   Content="{DynamicResource Status_AllViewers_Label}">
                                <Label.ToolTip>
                                    <TextBlock Text="{DynamicResource Tooltip_AllViewers}"/>
                                </Label.ToolTip>
                            </Label>
                            <Label Padding="3,0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CurrUserCount, FallbackValue=0, Mode=OneWay, StringFormat=\{0:N0\}}" />
                            </Label>
                        </StackPanel>
                    </StatusBarItem>

                    <Separator />

                    <StatusBarItem>
                        <Button Click="StatusBar_Button_UpdateFollows_Click" Background="{DynamicResource PartBackground}">
                            <StackPanel Orientation="Vertical">
                                <Label Padding="3,0" HorizontalAlignment="Center" 
                                       Content="{DynamicResource Status_CurrentFollows_Label}">
                                    <Label.ToolTip>
                                        <TextBlock Text="{DynamicResource Tooltip_CurrentFollows_Refresh}"/>
                                    </Label.ToolTip>
                                </Label>
                                <Label Padding="3,0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CurrFollowers, FallbackValue=0, StringFormat=\{0:N0\}}" Background="{x:Null}"/>
                                </Label>
                            </StackPanel>
                        </Button>
                    </StatusBarItem>

                    <Separator />

                    <StatusBarItem>
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Label Content="{DynamicResource Status_InstalledCommands_Label}" Padding="0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label ToolTip="Built-in Commands" Padding="3,0" 
                       Content="{DynamicResource Status_BuiltIn_Label}"/>
                                <Label Content="{Binding CurrBuiltInComCount, FallbackValue=0, NotifyOnSourceUpdated=True, StringFormat=\{0:N\}}"  
                       Padding="3,0" />
                                <Label ToolTip="User-Defined Commands" Padding="3,0" 
                       Content="{DynamicResource Status_UserDefined_Label}"/>
                                <Label Content="{Binding CurrUserComsCount, FallbackValue=0, NotifyOnSourceUpdated=True, StringFormat=\{0:N\}}" 
                       Padding="3,0" />
                            </StackPanel>
                        </StackPanel>
                    </StatusBarItem>

                    <Separator />

                    <StatusBarItem>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                            <Label ToolTip="{DynamicResource Tooltip_TokenExpiration}" Padding="0" 
                   Content="{DynamicResource Status_TokenExpiration_Label}"/>
                            <Label x:Name="StatusBarItem_TokenDate" Padding="0"/>
                        </StackPanel>
                    </StatusBarItem>

                    <Separator />

                    <StatusBarItem Padding="0,0,0,0">
                        <Button x:Name="Button_RefreshCategory" Grid.Column="0" 
                HorizontalAlignment="Left" VerticalAlignment="Center" 
                Padding="0" Click="Button_RefreshCategory_Click" 
                ToolTip="{DynamicResource Tooltip_Category_Refresh}">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                <Label Padding="5,5,5,0" Content="{DynamicResource Status_CurrentCategory_Label}"/>
                                <Label x:Name="TextBlock_CurrentCategory" Grid.Column="2" 
                       VerticalAlignment="Center" Padding="5,0,5,5"/>
                            </StackPanel>
                        </Button>
                    </StatusBarItem>
                </StatusBar>

                <TabControl DockPanel.Dock="Top" TabStripPlacement="Left">
                    <TabItem Header="{DynamicResource Bots_TabHeader}">
                        <TabControl x:Name="TabControl_Bots_Content">
                            <TabItem Header="{DynamicResource Bots_StartBots_TabHeader}">
                                <DockPanel>
                                    <Expander DockPanel.Dock="Top" 
                          Header="{DynamicResource Bots_UsageInfo_Header}" 
                          IsExpanded="{Binding ExpanderBotUsageInfo, Mode=OneWay}">
                                        <TextBlock Text="{DynamicResource Help_Bots_UsageInfo}" 
                               TextWrapping="Wrap" />
                                    </Expander>

                                    <StackPanel Orientation="Horizontal" 
                            DockPanel.Dock="Top" 
                            HorizontalAlignment="Center">
                                        <Button Content="{DynamicResource Bots_StartAll}" 
                            Click="GUIStartBots_Click" 
                            Margin="15,5" />
                                        <Button Content="{DynamicResource Bots_StopAll}" 
                            Click="GUIStopBots_Click" 
                            Margin="15,5" />
                                    </StackPanel>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <WrapPanel HorizontalAlignment="Center">

                                            <!-- ──────────────────────────────────────────────── -->
                                            <!-- EventSub Bot Chat -->
                                            <!-- ──────────────────────────────────────────────── -->
                                            <GroupBox Header="{DynamicResource Bot_EventSubChat}" 
                                  x:Name="GroupBox_Twitch_StartBots_EventSubBot">
                                                <WrapPanel>
                                                    <Border BorderBrush="{DynamicResource PartBackground}" 
                                        BorderThickness="2" Margin="5,10">
                                                        <Grid MinHeight="40" MaxWidth="220">
                                                            <Grid.Resources>
                                                                <Style TargetType="{x:Type TextBlock}"
                                                   BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                                </Style>
                                                            </Grid.Resources>

                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="10"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="160"/>
                                                                <ColumnDefinition Width="50"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{DynamicResource Bot_AccessAuthorized_Label}"/>
                                                            <TextBlock x:Name="TextBlock_EventSubChat_AccessToken_Valid" 
                                                   Grid.Column="1" 
                                                   Foreground="{DynamicResource BrightGo}" 
                                                   Visibility="Collapsed"
                                                   Text="{DynamicResource Bot_AccessValid}"/>
                                                            <TextBlock x:Name="TextBlock_EventSubChat_AccessToken_Invalid" 
                                                   Grid.Column="1" 
                                                   Foreground="{DynamicResource BrightStop}"
                                                   Visibility="Visible"
                                                   Text="{DynamicResource Bot_AccessInvalid}"/>

                                                            <TextBlock Grid.Row="3" Grid.ColumnSpan="2" 
                                                   x:Name="TextBlock_EventSubChat_ManualToken_Info" 
                                                   Foreground="{DynamicResource BrightStop}"
                                                   Visibility="Visible"
                                                   Text="{DynamicResource Help_Bot_EventSubChat_ManualToken}"/>
                                                            <TextBlock Grid.Row="3" Grid.ColumnSpan="2" 
                                                   x:Name="TextBlock_EventSubChat_AuthCode_Info" 
                                                   Foreground="{DynamicResource BrightStop}"
                                                   Visibility="Collapsed"
                                                   Text="{DynamicResource Help_Bot_EventSubChat_AuthCode}"/>
                                                        </Grid>
                                                    </Border>

                                                    <TextBlock Text="{DynamicResource Bot_EventSubChat_Description}"/>

                                                    <StackPanel Height="45">
                                                        <Label x:Name="Label_TwitchBot_EventSubBot_Start" Visibility="Collapsed">
                                                            <TextBlock Foreground="{DynamicResource Go}" Text="{DynamicResource Bot_EventSubChat_Start}" />
                                                        </Label>
                                                        <Label x:Name="Label_TwitchBot_EventSubBot_Stop" Visibility="Visible">
                                                            <TextBlock Foreground="{DynamicResource Stop}" Text="{DynamicResource Bot_EventSubChat_Stop}"/>
                                                        </Label>
                                                    </StackPanel>

                                                    <CheckBox DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" 
                                          IsChecked="{Binding TwitchBotEventSubAutoStart}">
                                                        <TextBlock Text="{DynamicResource Common_AutoStart}"/>
                                                    </CheckBox>

                                                    <RadioButton DataContext="{Binding TwitchEventSubBot, Mode=OneWay, Source={StaticResource TwitchBot}}" 
                                             x:Name="Radio_Twitch_EventSubBotStart" 
                                             IsEnabled="False" 
                                             PreviewMouseLeftButtonDown="RadioButton_StartBot_PreviewMouseLeftButtonDown">
                                                        <TextBlock Text="{DynamicResource Bot_Start_EventSubChat}"/>
                                                    </RadioButton>

                                                    <RadioButton DataContext="{Binding TwitchEventSubBot, Mode=OneWay, Source={StaticResource TwitchBot}}" 
                                             x:Name="Radio_Twitch_EventSubBotStop" 
                                             IsEnabled="False" IsChecked="True" 
                                             PreviewMouseLeftButtonUp="RadioButton_StopBot_PreviewMouseLeftButtonDown">
                                                        <TextBlock Text="{DynamicResource Bot_Stop_EventSubChat}"/>
                                                    </RadioButton>

                                                    <GroupBox Header="{DynamicResource Bot_ActivatePerOnline_Header}" 
                                          Width="Auto" Visibility="Collapsed">
                                                        <WrapPanel>
                                                            <CheckBox DataContext="{Binding TwitchBotEventSubConnectOnline, Mode=OneWay, Source={x:Static s:Settings.Default}}">
                                                                <TextBlock Text="{DynamicResource Bot_ConnectWhenOnline}"/>
                                                            </CheckBox>
                                                            <CheckBox DataContext="{Binding TwitchBotEventSubDisconnectOffline, Mode=OneWay, Source={x:Static s:Settings.Default}}">
                                                                <TextBlock Text="{DynamicResource Bot_DisconnectWhenOffline}"/>
                                                            </CheckBox>
                                                        </WrapPanel>
                                                    </GroupBox>
                                                </WrapPanel>
                                            </GroupBox>

                                            <!-- ──────────────────────────────────────────────── -->
                                            <!-- EventSub Bot Notifications -->
                                            <!-- ──────────────────────────────────────────────── -->
                                            <GroupBox Header="{DynamicResource Bot_EventSubNotifications}"
                                  x:Name="GroupBox_Twitch_StartBots_EventSubStreamer">
                                                <WrapPanel>
                                                    <Border BorderBrush="{DynamicResource PartBackground}" 
                                        BorderThickness="2" Margin="5,10">
                                                        <Grid MinHeight="40" MaxWidth="220">
                                                            <Grid.Resources>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                                </Style>
                                                            </Grid.Resources>

                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="10"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="170"/>
                                                                <ColumnDefinition Width="40"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Row="0" Text="{DynamicResource Bot_AccessAuthorizedScopes_Label}"/>
                                                            <TextBlock x:Name="TextBlock_EventSubNotify_AccessToken_Scopes_Valid" 
                                                   Grid.Column="1" 
                                                   Foreground="{DynamicResource BrightGo}" 
                                                   Visibility="Collapsed"
                                                   Text="{DynamicResource Bot_AccessValid}"/>
                                                            <TextBlock x:Name="TextBlock_EventSubNotify_AccessToken_Scopes_Invalid" 
                                                   Grid.Column="1" 
                                                   Foreground="{DynamicResource BrightStop}"
                                                   Visibility="Visible"
                                                   Text="{DynamicResource Bot_AccessInvalid}"/>

                                                            <TextBlock Grid.Row="1" Text="{DynamicResource Bot_AccessAuthorizedNoScopes_Label}"/>
                                                            <TextBlock x:Name="TextBlock_EventSubNotify_AccessToken_NoScopes_Valid" 
                                                   Grid.Row="1" Grid.Column="1" 
                                                   Foreground="{DynamicResource BrightGo}" 
                                                   Visibility="Collapsed"
                                                   Text="{DynamicResource Bot_AccessValid}"/>
                                                            <TextBlock x:Name="TextBlock_EventSubNotify_AccessToken_NoScopes_Invalid" 
                                                   Grid.Row="1" Grid.Column="1" 
                                                   Foreground="{DynamicResource BrightStop}"
                                                   Visibility="Visible"
                                                   Text="{DynamicResource Bot_AccessInvalid}"/>

                                                            <TextBlock Grid.Row="3" Grid.ColumnSpan="2" 
                                                   x:Name="TextBlock_EventSubNotify_ManualToken_Info" 
                                                   Foreground="{DynamicResource BrightStop}"
                                                   Visibility="Visible"
                                                   Text="{DynamicResource Help_Bot_EventSubNotify_ManualToken}"/>
                                                            <TextBlock Grid.Row="3" Grid.ColumnSpan="2" 
                                                   x:Name="TextBlock_EventSubNotify_AuthCode_Info" 
                                                   Foreground="{DynamicResource BrightStop}"
                                                   Visibility="Collapsed"
                                                   Text="{DynamicResource Help_Bot_EventSubNotify_AuthCode}"/>
                                                        </Grid>
                                                    </Border>

                                                    <TextBlock Text="{DynamicResource Bot_EventSubNotifications_Description}"/>

                                                    <StackPanel Height="45">
                                                        <Label x:Name="Label_TwitchBot_EventSubStreamer_Start" Visibility="Collapsed">
                                                            <TextBlock Foreground="{DynamicResource Go}" Text="{DynamicResource Bot_LiveMonitor_Start}" />
                                                        </Label>
                                                        <Label x:Name="Label_TwitchBot_EventSubStreamer_Stop" Visibility="Visible">
                                                            <TextBlock Foreground="{DynamicResource Stop}" Text="{DynamicResource Bot_LiveMonitor_Stop}" />
                                                        </Label>
                                                    </StackPanel>

                                                    <CheckBox DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" 
                                          IsChecked="{Binding TwitchStreamEventSubAutoStart}">
                                                        <TextBlock Text="{DynamicResource Common_AutoStart}"/>
                                                    </CheckBox>

                                                    <RadioButton DataContext="{Binding TwitchEventSubStreamer, Mode=OneWay, Source={StaticResource TwitchBot}}" 
                                             x:Name="Radio_Twitch_EventSubStreamerStart" 
                                             IsEnabled="False" 
                                             PreviewMouseLeftButtonDown="RadioButton_StartBot_PreviewMouseLeftButtonDown">
                                                        <TextBlock Text="{DynamicResource Bot_Start_EventSubNotifications}"/>
                                                    </RadioButton>

                                                    <RadioButton DataContext="{Binding TwitchEventSubStreamer, Mode=OneWay, Source={StaticResource TwitchBot}}" 
                                             x:Name="Radio_Twitch_EventSubStreamerStop" 
                                             IsEnabled="False" IsChecked="True" 
                                             PreviewMouseLeftButtonUp="RadioButton_StopBot_PreviewMouseLeftButtonDown">
                                                        <TextBlock Text="{DynamicResource Bot_Stop_EventSubNotifications}"/>
                                                    </RadioButton>

                                                    <GroupBox Header="{DynamicResource Bot_ActivatePerOnline_Header}" 
                                          Width="Auto" Visibility="Collapsed">
                                                        <WrapPanel>
                                                            <CheckBox DataContext="{Binding TwitchBotEventSubConnectOnline, Mode=OneWay, Source={x:Static s:Settings.Default}}">
                                                                <TextBlock Text="{DynamicResource Bot_ConnectWhenOnline}"/>
                                                            </CheckBox>
                                                            <CheckBox DataContext="{Binding TwitchBotEventSubDisconnectOffline, Mode=OneWay, Source={x:Static s:Settings.Default}}">
                                                                <TextBlock Text="{DynamicResource Bot_DisconnectWhenOffline}"/>
                                                            </CheckBox>
                                                        </WrapPanel>
                                                    </GroupBox>
                                                </WrapPanel>
                                            </GroupBox>

                                            <!-- The other GroupBoxes (Live Monitor, Clip Service, Media Overlay) follow the exact same pattern -->

                                            <GroupBox Header="{DynamicResource Bot_LiveMonitor}">
                                                <StackPanel Orientation="Vertical">
                                                    <WrapPanel>
                                                        <TextBlock Text="{DynamicResource Bot_LiveMonitor_Description}"/>

                                                        <StackPanel Height="45">
                                                            <Label x:Name="Label_TwitchMultiLive_Start" Visibility="Collapsed">
                                                                <TextBlock Foreground="{DynamicResource Go}" Text="{DynamicResource Bot_LiveMonitor_Start}" />
                                                            </Label>
                                                            <Label x:Name="Label_TwitchMultiLive_Stop" Visibility="Visible">
                                                                <TextBlock Foreground="{DynamicResource Stop}" Text="{DynamicResource Bot_LiveMonitor_Stop}" />
                                                            </Label>
                                                        </StackPanel>

                                                        <CheckBox DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" 
                                              IsChecked="{Binding TwitchLiveStreamSvcAutoStart}">
                                                            <TextBlock Text="{DynamicResource Common_AutoStart}"/>
                                                        </CheckBox>

                                                        <RadioButton DataContext="{Binding TwitchBotLiveMonitorSvc, Mode=OneWay, Source={StaticResource TwitchBot}}" 
                                                 x:Name="Radio_Twitch_LiveBotStart" 
                                                 IsEnabled="False" 
                                                 PreviewMouseLeftButtonDown="RadioButton_StartBot_PreviewMouseLeftButtonDown">
                                                            <TextBlock Text="{DynamicResource Bot_Start_LiveMonitor}"/>
                                                        </RadioButton>

                                                        <RadioButton DataContext="{Binding TwitchBotLiveMonitorSvc, Mode=OneWay, Source={StaticResource TwitchBot}}" 
                                                 x:Name="Radio_Twitch_LiveBotStop" 
                                                 IsEnabled="False" IsChecked="True" 
                                                 PreviewMouseLeftButtonDown="RadioButton_StopBot_PreviewMouseLeftButtonDown">
                                                            <TextBlock Text="{DynamicResource Bot_Stop_LiveMonitor}"/>
                                                        </RadioButton>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- ──────────────────────────────────────────────── -->
                                            <!-- Streamer-Clip Service -->
                                            <!-- ──────────────────────────────────────────────── -->
                                            <GroupBox Header="{DynamicResource Bot_ClipService}">
                                                <WrapPanel>
                                                    <StackPanel Height="45">
                                                        <Label x:Name="Label_TwitchClip_Start" Visibility="Collapsed">
                                                            <TextBlock Foreground="{DynamicResource Go}" Text="{DynamicResource Bot_ClipService_Start}" />
                                                        </Label>
                                                        <Label x:Name="Label_TwitchClip_Stop" Visibility="Visible">
                                                            <TextBlock Foreground="{DynamicResource Stop}" Text="{DynamicResource Bot_ClipService_Stop}" />
                                                        </Label>
                                                    </StackPanel>

                                                    <CheckBox DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" 
                                          IsChecked="{Binding TwitchClipAutoStart}">
                                                        <TextBlock Text="{DynamicResource Common_AutoStart}"/>
                                                    </CheckBox>

                                                    <RadioButton DataContext="{Binding TwitchClip, Mode=OneWay, Source={StaticResource TwitchBot}}" 
                                             x:Name="Radio_Twitch_ClipBotStart" 
                                             IsEnabled="False" 
                                             PreviewMouseLeftButtonDown="RadioButton_StartBot_PreviewMouseLeftButtonDown">
                                                        <TextBlock Text="{DynamicResource Bot_Start_ClipService}"/>
                                                    </RadioButton>

                                                    <RadioButton DataContext="{Binding TwitchClip, Mode=OneWay, Source={StaticResource TwitchBot}}" 
                                             x:Name="Radio_Twitch_ClipBotStop" 
                                             IsEnabled="False" IsChecked="True" 
                                             PreviewMouseLeftButtonDown="RadioButton_StopBot_PreviewMouseLeftButtonDown">
                                                        <TextBlock Text="{DynamicResource Bot_Stop_ClipService}"/>
                                                    </RadioButton>

                                                    <Label x:Name="Label_TwitchClip_Error" Visibility="Collapsed" Height="Auto">
                                                        <TextBlock Foreground="{DynamicResource Stop}">
                                        <Run Text="{DynamicResource Bot_ClipService_Error}"/>
                                                        </TextBlock>
                                                    </Label>

                                                    <GroupBox Header="{DynamicResource Bot_ActivatePerOnline_Header}" Width="Auto">
                                                        <StackPanel>
                                                            <CheckBox DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" 
                                                  IsChecked="{Binding TwitchClipConnectOnline}">
                                                                <TextBlock Text="{DynamicResource Bot_ConnectWhenOnline}"/>
                                                            </CheckBox>
                                                            <CheckBox DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" 
                                                  IsChecked="{Binding TwitchClipDisconnectOffline}">
                                                                <TextBlock Text="{DynamicResource Bot_DisconnectWhenOffline}"/>
                                                            </CheckBox>
                                                        </StackPanel>
                                                    </GroupBox>
                                                </WrapPanel>
                                            </GroupBox>

                                            <!-- ──────────────────────────────────────────────── -->
                                            <!-- Service-Media Overlay -->
                                            <!-- ──────────────────────────────────────────────── -->
                                            <GroupBox Header="{DynamicResource Bot_MediaOverlay}">
                                                <WrapPanel>
                                                    <StackPanel Height="45">
                                                        <Label x:Name="Label_OverlayService_Start" Visibility="Collapsed">
                                                            <TextBlock Foreground="{DynamicResource Go}" Text="{DynamicResource Bot_MediaOverlay_Start}" />
                                                        </Label>
                                                        <Label x:Name="Label_OverlayService_Stop" Visibility="Visible">
                                                            <TextBlock Foreground="{DynamicResource Stop}" Text="{DynamicResource Bot_MediaOverlay_Stop}" />
                                                        </Label>
                                                    </StackPanel>

                                                    <TextBlock Text="{DynamicResource Help_Overlay_Intro}"/>

                                                    <CheckBox DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" 
                                          IsChecked="{Binding MediaOverlayAutoStart}">
                                                        <TextBlock Text="{DynamicResource Common_AutoStart}" />
                                                    </CheckBox>

                                                    <RadioButton DataContext="{Binding MediaOverlayServer, Mode=OneWay, Source={StaticResource AppServices}}" 
                                             x:Name="Radio_Services_OverlayBotStart" 
                                             IsEnabled="False" 
                                             PreviewMouseLeftButtonDown="RadioButton_StartBot_PreviewMouseLeftButtonDown">
                                                        <TextBlock Text="{DynamicResource Bot_Start_MediaOverlay}"/>
                                                    </RadioButton>

                                                    <RadioButton DataContext="{Binding MediaOverlayServer, Mode=OneWay, Source={StaticResource AppServices}}" 
                                             x:Name="Radio_Services_OverlayBotStop" 
                                             IsEnabled="False" IsChecked="True" 
                                             PreviewMouseLeftButtonUp="RadioButton_StopBot_PreviewMouseLeftButtonDown">
                                                        <TextBlock Text="{DynamicResource Bot_Stop_MediaOverlay}"/>
                                                    </RadioButton>

                                                    <Label x:Name="Label_OverlayServer_Error" Visibility="Collapsed" Height="Auto">
                                                        <TextBlock Foreground="{DynamicResource Stop}">
                                        <Run Text="{DynamicResource Bot_MediaOverlay_Error}"/>
                                                        </TextBlock>
                                                    </Label>

                                                    <GroupBox Header="{DynamicResource Bot_ActivatePerOnline_Header}" Width="Auto">
                                                        <WrapPanel Orientation="Vertical">
                                                            <CheckBox DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" 
                                                  IsChecked="{Binding MediaOverlayStartWithStream}">
                                                                <TextBlock Text="{DynamicResource Bot_MediaOverlay_StartWithStream}"/>
                                                            </CheckBox>
                                                        </WrapPanel>
                                                    </GroupBox>
                                                </WrapPanel>
                                            </GroupBox>

                                        </WrapPanel>
                                    </ScrollViewer>
                                </DockPanel>
                            </TabItem>

                            <TabItem Header="{DynamicResource Bots_Twitch_TabHeader}" DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}">
                                <TabItem.Resources>
                                    <Style TargetType="{x:Type Label}" BasedOn="{StaticResource {x:Type Label}}">
                                        <Setter Property="Width" Value="120" />
                                    </Style>
                                    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="Width" Value="250" />
                                        <Setter Property="Height" Value="Auto" />
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                    </Style>
                                </TabItem.Resources>

                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Top">
                                        <ToggleButton x:Name="ToggleButton_TwitchToken" Width="100" Height="36" 
                                                      IsChecked="{Binding TwitchTokenUseAuth}"
                                                      Click="ToggleButton_ChooseTwitchAuth_Click" ClickMode="Press" 
                                                      Style="{StaticResource ToggleButtonTwitchTokenSelecter}"/>
                                    </StackPanel>

                                    <GroupBox Header="{DynamicResource Bots_Twitch_Settings_Header}" Width="Auto" Height="Auto" 
                                                DockPanel.Dock="Bottom" Visibility="Visible">
                                        <WrapPanel Orientation="Horizontal">

                                            <!-- Setup Clip Operations -->
                                            <GroupBox Header="{DynamicResource Bots_Twitch_ClipSetup_Header}" Width="Auto">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Label Width="Auto" Content="{DynamicResource Bots_Twitch_ClipCheckSeconds_Label}"/>
                                                        <Label Width="Auto" Content="{Binding Value, ElementName=Slider_TimeClipPollSeconds}" />
                                                    </StackPanel>
                                                    <Slider x:Name="Slider_TimeClipPollSeconds" Height="40" Width="Auto" 
                                AutoToolTipPlacement="TopLeft" Interval="1" TickPlacement="Both" 
                                ToolTip="{DynamicResource Bots_Twitch_ClipCheckSeconds_Tooltip}"
                                Value="{Binding TwitchFrequencyClipTime, Mode=TwoWay}" Maximum="1200" Minimum="5" 
                                SmallChange="1" SelectionStart="0" SelectionEnd="1200" Margin="10,0" 
                                IsSnapToTickEnabled="True" LostFocus="Settings_LostFocus" LargeChange="50" TickFrequency="5" />
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Setup Go-Live Notifications -->
                                            <GroupBox Header="{DynamicResource Bots_Twitch_GoLiveSetup_Header}" Width="Auto">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Label Width="Auto" Content="{DynamicResource Bots_Twitch_GoLiveCheckSeconds_Label}"/>
                                                        <Label Width="Auto" Content="{Binding Value, ElementName=Slider_TimeGoLivePollSeconds}" />
                                                    </StackPanel>
                                                    <Slider x:Name="Slider_TimeGoLivePollSeconds" Height="40" Width="Auto" 
                                AutoToolTipPlacement="TopLeft" Interval="1" TickPlacement="Both" 
                                ToolTip="{DynamicResource Bots_Twitch_GoLiveCheckSeconds_Tooltip}"
                                Value="{Binding TwitchGoLiveFrequency, Mode=TwoWay}" Maximum="3600" Minimum="0" 
                                SmallChange="5" SelectionStart="5" SelectionEnd="3600" Margin="10,0" 
                                IsSnapToTickEnabled="True" LostFocus="Settings_LostFocus" LargeChange="50" TickFrequency="10" />
                                                </StackPanel>
                                            </GroupBox>

                                        </WrapPanel>
                                    </GroupBox>

                                    <DockPanel DockPanel.Dock="Top" VerticalAlignment="Stretch">
                                        <DockPanel x:Name="StackPanel_TwitchTokenFlow" Visibility="Visible">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                <DockPanel>
                                                    <WrapPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <GroupBox x:Name="GroupBox_Twitch_BotCredentials" 
                                      Header="{DynamicResource Bots_Twitch_BotCredentials_Header}" Width="450">
                                                            <StackPanel>
                                                                <TextBlock x:Uid="ExpiredToken" 
                                               x:Name="TextBlock_ExpiredCredentialsMsg" 
                                               Foreground="#FFF71553"
                                               FontSize="18" HorizontalAlignment="Center" 
                                               MaxWidth="550" TextAlignment="Center" 
                                               Visibility="Collapsed" 
                                               Text="{DynamicResource Bots_Twitch_ExpiredCredentials}" />

                                                                <StackPanel Orientation="Horizontal" Margin="10">
                                                                    <Label Content="{DynamicResource Bots_Twitch_ChannelName_Label}" />
                                                                    <TextBox x:Name="TB_Twitch_Channel" 
                                                 Text="{Binding TwitchChannelName}" 
                                                 SourceUpdated="TextBox_SourceUpdated" 
                                                 PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" 
                                                 TargetUpdated="TextBox_TwitchChannelBotNames_TargetUpdated" 
                                                 TextChanged="TextBox_TextChanged" 
                                                 TextInput="TextBox_TextChanged" 
                                                 LostFocus="TextBox_TextChanged" />
                                                                </StackPanel>

                                                                <StackPanel Orientation="Horizontal" Margin="10,0">
                                                                    <Label Content="{DynamicResource Bots_Twitch_TokenScope_Label}" />
                                                                    <TextBox x:Name="TextBox_TwitchScopesDiffOauthBot" 
                                                 BorderBrush="Blue" BorderThickness="1" 
                                                 IsReadOnly="True" 
                                                 PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" 
                                                 SourceUpdated="TextBox_SourceUpdated" 
                                                 DataContext="" 
                                                 Text="{Binding Mode=OneWay, Source={x:Static StaticLib:OptionFlags.CredentialsTwitchScopesDiffOauthBot}}" />
                                                                    <TextBox x:Name="TextBox_TwitchScopesOauthSame" 
                                                 BorderBrush="Blue" BorderThickness="1" 
                                                 IsReadOnly="True" 
                                                 PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" 
                                                 Visibility="Collapsed" 
                                                 SourceUpdated="TextBox_SourceUpdated" 
                                                 DataContext="" 
                                                 Text="{Binding Mode=OneWay, Source={x:Static StaticLib:OptionFlags.CredentialsTwitchScopesOauthSame}}" />
                                                                </StackPanel>

                                                                <TextBlock Width="300" 
                                               Text="{DynamicResource Bots_Twitch_SingleChannelNote}" 
                                               TextWrapping="Wrap" FontSize="8" 
                                               FontStretch="SemiCondensed" />

                                                                <StackPanel Orientation="Horizontal" Margin="10">
                                                                    <Label Content="{DynamicResource Bots_Twitch_BotUserName_Label}" />
                                                                    <TextBox x:Name="TB_Twitch_BotUser" 
                                                 Text="{Binding TwitchBotUserName, Mode=TwoWay}" 
                                                 SourceUpdated="TextBox_SourceUpdated" 
                                                 PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" 
                                                 TargetUpdated="TextBox_TwitchChannelBotNames_TargetUpdated" 
                                                 TextChanged="TextBox_TextChanged" 
                                                 TextInput="TextBox_TextChanged" 
                                                 LostFocus="TextBox_TextChanged" />
                                                                </StackPanel>

                                                                <StackPanel Orientation="Horizontal" Margin="10">
                                                                    <Button x:Name="Btn_Twitch_RefreshDate" 
                                                Content="{DynamicResource Bots_Twitch_RefreshDueDate_Button}" 
                                                Width="110" 
                                                ToolTip="{DynamicResource Bots_Twitch_RefreshDueDate_Tooltip}"
                                                Click="RefreshButton_Click" 
                                                LostFocus="Settings_LostFocus" />
                                                                    <Label x:Name="Label_Twitch_RefreshDate" 
                                               Width="Auto" 
                                               Content="{Binding TwitchBotTokenDate, FallbackValue=1/1/1900, Mode=TwoWay, StringFormat=MM/dd/yyyy}" />
                                                                </StackPanel>

                                                                <Expander x:Name="Expander_Credentials" 
                                              IsExpanded="False"
                                              Width="420">
                                                                    <Expander.Header>
                                                                        <TextBlock Text="{DynamicResource Bots_Twitch_Credentials_ExpanderHeader}"/>
                                                                    </Expander.Header>
                                                                    <StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="10">
                                                                            <Label Content="{DynamicResource Bots_Twitch_ClientId_Label}" />
                                                                            <TextBox x:Name="TB_Twitch_ClientID" 
                                                         Text="{Binding TwitchBotClientID, Mode=TwoWay}"
                                                         ToolTip="{DynamicResource Bots_Twitch_ClientId_Tooltip}" 
                                                         PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" 
                                                         SourceUpdated="TextBox_SourceUpdated"  
                                                         TargetUpdated="TextBox_SourceUpdated" />
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="10">
                                                                            <Label Content="{DynamicResource Bots_Twitch_AccessToken_Label}" />
                                                                            <TextBox x:Name="TB_Twitch_AccessToken" 
                                                         Text="{Binding TwitchBotAccessToken, Mode=TwoWay}" 
                                                         PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" 
                                                         SourceUpdated="TextBox_SourceUpdated"  
                                                         TargetUpdated="TextBox_SourceUpdated" />
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="10">
                                                                            <Label Content="{DynamicResource Bots_Twitch_RefreshToken_Label}"  />
                                                                            <TextBox x:Name="TB_Twitch_RefreshToken" 
                                                         Text="{Binding TwitchBotRefreshToken, Mode=TwoWay}"
                                                         PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" 
                                                         SourceUpdated="TextBox_SourceUpdated"  
                                                         TargetUpdated="TextBox_SourceUpdated" />
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="10" 
                                                        x:Name="SP_Twitch_UserToken_NoScopes_Bot">
                                                                            <TextBlock Text="{DynamicResource Bots_Twitch_NoScopesExplanation}"/>
                                                                            <Label Content="{DynamicResource Bots_Twitch_NoScopesToken_Label}"/>
                                                                            <TextBox TextWrapping="Wrap" 
                                                         Text="{Binding TwitchStreamerNoScopesAccessToken, Mode=TwoWay}" 
                                                         PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"
                                                         SourceUpdated="TextBox_SourceUpdated" />
                                                                            <Button x:Name="Btn_Twitch_RefreshDate_NoScopes" 
                                                        Content="{DynamicResource Bots_Twitch_RefreshDueDate_Button}" Width="110" 
                                                        ToolTip="{DynamicResource Bots_Twitch_RefreshDueDate_Tooltip}"
                                                        Click="RefreshButtonNoScopes_Click" 
                                                        LostFocus="Settings_LostFocus" />
                                                                            <Label x:Name="Label_Twitch_RefreshDate_NoScopes"
                                                       Width="Auto" 
                                                       Content="{Binding TwitchStreamerNoScopesTokenDate, FallbackValue=1/1/1900, Mode=TwoWay, StringFormat=MM/dd/yyyy}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Expander>
                                                            </StackPanel>
                                                        </GroupBox>

                                                        <GroupBox x:Name="GroupBox_Twitch_AdditionalStreamerCredentials" 
                                      Header="{DynamicResource Bots_Twitch_StreamerCredentials_Header}" 
                                      Visibility="Collapsed" Width="450">
                                                            <StackPanel>
                                                                <TextBlock Text="{DynamicResource Bots_Twitch_StreamerCredentials_Explanation}" 
                                               Width="400" TextWrapping="Wrap"/>
                                                                <StackPanel Orientation="Horizontal" Margin="10">
                                                                    <TextBlock x:Uid="ExpiredToken"
                                                   x:Name="TextBlock_ExpiredStreamerCredentialsMsg" 
                                                   Foreground="#FFF71553" 
                                                   FontSize="18" HorizontalAlignment="Center"
                                                   MaxWidth="550" TextAlignment="Center" 
                                                   Visibility="Collapsed" Text="{DynamicResource Bots_Twitch_ExpiredCredentials}" />
                                                                    <Button x:Name="Btn_Twitch_RefreshDate_Streamer"
                                                Content="{DynamicResource Bots_Twitch_RefreshDueDate_Button}" Width="110"
                                                ToolTip="{DynamicResource Bots_Twitch_RefreshDueDate_Tooltip}" 
                                                Click="RefreshStreamButton_Click" 
                                                LostFocus="Settings_LostFocus" />
                                                                    <Label x:Name="Label_Twitch_StreamerRefreshDate" 
                                               Width="Auto" Content="{Binding TwitchStreamerTokenDate, FallbackValue=1/1/1900, Mode=TwoWay, StringFormat=MM/dd/yyyy}" />
                                                                </StackPanel>
                                                                <TextBlock Text="{DynamicResource Bots_Twitch_StreamerFeatures_Label}"/>
                                                                <ListBox ItemsSource="{DynamicResource CredentialsTwitchStreamerFeatures}" />
                                                                <Expander Width="420" HorizontalAlignment="Left">
                                                                    <Expander.Header>
                                                                        <TextBlock Text="{DynamicResource Bots_Twitch_StreamerCredentials_ExpanderHeader}"/>
                                                                    </Expander.Header>
                                                                    <StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="10">
                                                                            <Label Content="{DynamicResource Bots_Twitch_ClientId_Label}"/>
                                                                            <TextBox TextWrapping="Wrap" 
                                                         Text="{Binding TwitchStreamerClientId, Mode=TwoWay}"
                                                         PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" 
                                                         ToolTip="{DynamicResource Bots_Twitch_ClientId_Tooltip}" 
                                                         SourceUpdated="TextBox_SourceUpdated" />
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="10">
                                                                            <Label Content="{DynamicResource Bots_Twitch_TokenScope_Label}" />
                                                                            <TextBox BorderBrush="Blue" BorderThickness="1" 
                                                         SourceUpdated="TextBox_SourceUpdated" 
                                                         PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" 
                                                         Text="{x:Static StaticLib:OptionFlags.CredentialsTwitchScopesDiffOauthChannel}" />
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="10">
                                                                            <Label Content="{DynamicResource Bots_Twitch_AccessToken_Label}"/>
                                                                            <TextBox TextWrapping="Wrap" x:Name="TB_TwitchStreamerAccessToken"
                                                         Text="{Binding TwitchStreamerAccessToken, Mode=TwoWay}" 
                                                         PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"
                                                         SourceUpdated="TextBox_SourceUpdated" />
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Vertical" Margin="10" 
                                                        x:Name="SP_Twitch_UserToken_NoScopes_Streamer">
                                                                            <TextBlock TextWrapping="Wrap" Text="{DynamicResource Bots_Twitch_NoScopesExplanation}"/>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Label Content="{DynamicResource Bots_Twitch_NoScopesToken_Label}"/>
                                                                                <TextBox TextWrapping="Wrap" 
                                                             Text="{Binding TwitchStreamerNoScopesAccessToken, Mode=TwoWay}" 
                                                             PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"
                                                             SourceUpdated="TextBox_SourceUpdated" />
                                                                            </StackPanel>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Button x:Name="Btn_Twitch_RefreshDate_NoScopesStreamer" 
                                                            Content="{DynamicResource Bots_Twitch_RefreshDueDate_Button}" Width="110" 
                                                            ToolTip="{DynamicResource Bots_Twitch_RefreshDueDate_Tooltip}"
                                                            Click="RefreshButtonNoScopes_Click" 
                                                            LostFocus="Settings_LostFocus" />
                                                                                <Label x:Name="Label_Twitch_RefreshDate_NoScopesStreamer"
                                                           Width="Auto"
                                                           Content="{Binding TwitchStreamerNoScopesTokenDate, FallbackValue=1/1/1900, Mode=TwoWay, StringFormat=MM/dd/yyyy}" />
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Expander>
                                                            </StackPanel>
                                                        </GroupBox>
                                                    </WrapPanel>

                                                    <!-- Credentials help expander -->
                                                    <DockPanel DockPanel.Dock="Top">
                                                        <TextBlock DockPanel.Dock="Top" 
                                                              Foreground="Red" 
                                                              HorizontalAlignment="Center"
                                                              Text="{DynamicResource Credentials_ReauthWarning}"/>

                                                        <!-- Load the external help page here -->
                                                        <Frame DockPanel.Dock="Top"
                                                              Source="pack://application:,,,/Twitch/ManualTokenHelp.xaml"
                                                              IsManipulationEnabled="True"
                                                              NavigationUIVisibility="Hidden"
                                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                              Margin="0,5,0,10"/>

                                                    </DockPanel>
                                                </DockPanel>
                                            </ScrollViewer>
                                        </DockPanel>

                                        <DockPanel x:Name="StackPanel_TwitchAuthCodeFlow" DockPanel.Dock="Right"  Visibility="Visible"
                       VerticalAlignment="Stretch"
                       HorizontalAlignment="Stretch">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">

                                                <DockPanel ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto" >
                                                    <WrapPanel DockPanel.Dock="Bottom" Orientation="Horizontal">
                                                        <GroupBox Header="{DynamicResource Bots_Twitch_BotAccount_Header}" Width="410">
                                                            <Expander x:Name="Expander_CredentialsAuthBot" 
                                          ExpandDirection="Down" IsExpanded="False">
                                                                <Expander.Header>
                                                                    <TextBlock Text="{DynamicResource Bots_Twitch_HiddenPrivacy}"/>
                                                                </Expander.Header>
                                                                <StackPanel Orientation="Vertical" Margin="10">
                                                                    <StackPanel Orientation="Horizontal" Margin="10">
                                                                        <TextBlock Width="90" Text="{DynamicResource Bots_Twitch_ClientId_Label}"/>
                                                                        <TextBox Text="{Binding TwitchAuthBotClientId}" SourceUpdated="TextBox_SourceUpdated"  
                                                     TargetUpdated="TextBox_SourceUpdated" 
                                                     PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" />
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="10">
                                                                        <TextBlock Width="90" Text="{DynamicResource Bots_Twitch_ClientSecret_Label}"/>
                                                                        <TextBox Text="{Binding TwitchAuthBotClientSecret}" 
                                                     SourceUpdated="TextBox_SourceUpdated"  
                                                     TargetUpdated="TextBox_SourceUpdated" PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll" />
                                                                    </StackPanel>
                                                                    <CheckBox Visibility="Collapsed" IsChecked="{Binding TwitchAuthUseInternalBrowser}">
                                                                        <CheckBox.ToolTip>
                                                                            <TextBlock Text="{DynamicResource Bots_Twitch_InternalBrowser_Tooltip}"/>
                                                                        </CheckBox.ToolTip>
                                                                        <TextBlock Text="{DynamicResource Bots_Twitch_UseInternalBrowser}"/>
                                                                    </CheckBox>
                                                                    <TextBlock Foreground="{DynamicResource BrightStop}" Text="{DynamicResource Bots_Twitch_LoginFirstBot}"/>
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                        <Button x:Name="Twitch_AuthCode_Button_AuthorizeBot" 
                                                    Content="{DynamicResource Bots_Twitch_AuthorizeBotToken}" 
                                                    Width="160" Margin="5" 
                                                    Click="Button_TwitchAuthCode_ApproveBotURL" />
                                                                        <Button x:Name="Twitch_AuthCode_Button_AuthorizeBot_Reauthorize" 
                                                    Content="{DynamicResource Bots_Twitch_ClearBotToken}" 
                                                    Width="160" Margin="5" 
                                                    Click="Button_TwitchAuthToken_ReAuthorize" />
                                                                    </StackPanel>

                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Button x:Name="Twitch_AuthCode_NoScopes_Button_AuthorizeBot" 
                                                    Visibility="Collapsed" Content="{DynamicResource Bots_Twitch_AuthorizeNoScopes}" 
