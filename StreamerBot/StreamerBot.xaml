                          PreviewKeyDown="DG_PreviewKeyDown_Click"
                          RowEditEnding="DataGrid_RowEditEnding" 
                          ContextMenuOpening="DG_Edit_ContextMenuOpening">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="{DynamicResource Data_Clips_ClipId_Column}" 
                                            Binding="{Binding ClipId}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridTextColumn Header="{DynamicResource Data_Clips_Duration_Column}" 
                                            Binding="{Binding Duration}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridTemplateColumn Header="{DynamicResource Data_Clips_CreatedAt_Column}" 
                                                CellTemplate="{StaticResource DateClipCreatedTemplate}" 
                                                SortDirection="Descending" SortMemberPath="CreatedAt" />
                                                        <DataGridTextColumn Header="{DynamicResource Data_StreamData_Category_Column}" 
                                            Binding="{Binding CategoryList.Category}" 
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                    </DataGrid.Columns>
                                                    <DataGrid.GroupStyle>
                                                        <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                    </DataGrid.GroupStyle>
                                                </DataGrid>
                                            </Grid>
                                        </TabItem>
                                    </TabControl>
                                </TabItem>

                                <TabItem x:Name="TabItem_Data_Separator" 
                                     IsEnabled="False" MinWidth="20" 
                                     Width="20" Height="10" Visibility="Visible" />
                                <!-- MultiLive Monitor sub-tab -->
                                <TabItem x:Name="TabItem_Data_MultiLive" 
         Header="{DynamicResource Data_MultiLive_SubHeader}" 
         Visibility="Visible">
                                    <Frame x:Name="MultiLive_Data" 
           Source="pack://application:,,,/StreamerBotLib;component/Systems/MultiLive/MultiLiveDataGrids.xaml" 
           IsManipulationEnabled="True" 
           Loaded="MultiLive_Data_Loaded" />
                                </TabItem>
                            </TabControl>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="{DynamicResource Logs_TabHeader}">
                        <TabControl>
                            <TabItem Header="{DynamicResource Logs_BotStatus_Tab}">
                                <TabItem.Resources>
                                    <DataTemplate x:Key="AppStatTemplate">
                                        <StackPanel Orientation="Horizontal">
                                            <Label Width="200" Content="{Binding Name}" />
                                            <Label Content="{Binding Value, Converter={StaticResource AppDataConverter}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                    <Style TargetType="{x:Type ListBoxItem}">
                                        <Setter Property="ContentTemplate" Value="{StaticResource AppStatTemplate}" />
                                    </Style>
                                </TabItem.Resources>

                                <ListBox DataContext="{DynamicResource AppStats}" 
                     BorderBrush="{DynamicResource ForegroundText}" 
                     BorderThickness="2,2,1,2" Padding="5">
                                    <ListBoxItem Content="{Binding Header}" 
                             BorderThickness="0,0,0,1" 
                             BorderBrush="{DynamicResource ForegroundText}" />
                                    <ListBoxItem Content="{Binding Threads}" />
                                    <ListBoxItem Content="{Binding ClosedThreads}" />
                                    <ListBoxItem Content="{Binding Uptime}" />
                                </ListBox>
                            </TabItem>

                            <TabItem Header="{DynamicResource Logs_TwitchStatus_Tab}" GotFocus="TabItem_GotFocus">
                                <GroupBox Header="{DynamicResource Logs_BotStatusLog_Header}" 
                      BorderBrush="Black" Width="Auto">
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal" 
                                DockPanel.Dock="Top" 
                                DataContext="{Binding Source={x:Static s:Settings.Default}}">
                                            <CheckBox IsChecked="{Binding LogBotStatus}" 
                                  Margin="3" 
                                  ToolTip="{DynamicResource Logs_BotStatusLog_Tooltip}">
                                                <TextBlock Text="{DynamicResource Logs_EnableBotStatus}"/>
                                            </CheckBox>
                                            <CheckBox IsChecked="{Binding LogExceptions}" 
                                  Margin="3" 
                                  ToolTip="{DynamicResource Logs_ExceptionsLog_Tooltip}">
                                                <TextBlock Text="{DynamicResource Logs_EnableExceptions}"/>
                                            </CheckBox>
                                        </StackPanel>

                                        <!-- Your original commented-out TextBox is preserved unchanged -->
                                        <!--
                    <TextBox x:Name="TextBlock_TwitchBotLog" 
                             DataContext="{Binding TwitchChat, Mode=OneWay, Source={StaticResource TwitchBot}}" 
                             Text="{Binding StatusLog, Mode=OneWay}" 
                             TextWrapping="Wrap" Width="Auto" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto" 
                             IsReadOnly="True" 
                             VerticalScrollBarVisibility="Visible" 
                             IsInactiveSelectionHighlightEnabled="True" 
                             TextChanged="TextBox_TwitchBotLog_TextChanged" />
                    -->
                                    </DockPanel>
                                </GroupBox>
                            </TabItem>
                        </TabControl>
                    </TabItem>

                    <TabItem Header="{DynamicResource UserJoin_TabHeader}">
                        <DockPanel LastChildFill="True">
                            <DockPanel LastChildFill="True" DockPanel.Dock="Left" Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="25" />
                                        <RowDefinition Height="25"/>
                                        <RowDefinition Height="100"/>
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <Label Grid.Row="0" Content="{DynamicResource UserJoin_Instructions1}" HorizontalContentAlignment="Center" Grid.RowSpan="3" />
                                    <Label Grid.Row="1" Content="{DynamicResource UserJoin_Instructions2}" HorizontalContentAlignment="Center" Grid.RowSpan="3" />
                                    <GroupBox Grid.Row="2" Padding="10" Header="{DynamicResource UserJoin_Status_Header}"  >
                                        <StackPanel DataContext="{Binding Source={x:Static s:Settings.Default}}">
                                            <RadioButton IsChecked="{Binding UserPartyStart, Mode=TwoWay}" >
                                                <TextBlock Text="{DynamicResource UserJoin_Start}"/>
                                            </RadioButton>
                                            <RadioButton IsChecked="{Binding UserPartyStop, Mode=TwoWay}" >
                                                <TextBlock Text="{DynamicResource UserJoin_Stop}"/>
                                            </RadioButton>
                                        </StackPanel>
                                    </GroupBox>
                                    <ListView Grid.Row="3" x:Name="LV_JoinList" MaxWidth="500"
                          ItemsSource="{Binding JoinCollection, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True}" 
                          SelectionMode="Single" Margin="0,0,0,10" d:ItemsSource="{d:SampleData ItemCount=5}">
                                        <ListView.Resources>
                                            <DataTemplate x:Key="GridColCheck">
                                                <CheckBox IsChecked="{Binding Remove, Mode=TwoWay, NotifyOnTargetUpdated=True, UpdateSourceTrigger=PropertyChanged}" 
                                      Checked="JoinCollectionCheckBox_Checked" AutomationProperties.IsRowHeader="False" />
                                            </DataTemplate>
                                        </ListView.Resources>
                                        <ListView.DataContext>
                                            <Binding Source="{StaticResource DataViews}"/>
                                        </ListView.DataContext>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="{DynamicResource UserJoin_Remove_Column}" Width="70" CellTemplate="{DynamicResource GridColCheck}" />
                                                <GridViewColumn Header="{DynamicResource UserJoin_GameTagUserName_Column}" Width="200" DisplayMemberBinding="{Binding GameUserName, Mode=OneWay, UpdateSourceTrigger=Default}" />
                                                <GridViewColumn Header="{DynamicResource UserJoin_ChatUser_Column}" Width="200" DisplayMemberBinding="{Binding ChatUser, Mode=OneWay, UpdateSourceTrigger=Default}" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </DockPanel>
                            <DockPanel Visibility="Collapsed">
                                <Label Content="{DynamicResource UserJoin_CurrentList_Label}" DockPanel.Dock="Top" />
                                <ListView DataContext="{DynamicResource DataViews}" ItemsSource="{Binding CurrUserList}" Width="200" DockPanel.Dock="Top" ScrollViewer.CanContentScroll="True" d:ItemsSource="{d:SampleData ItemCount=5}">
                                    <ListView.ToolTip>
                                        <TextBlock TextWrapping="Wrap" Width="80" Text="{DynamicResource UserJoin_CurrentList_Tooltip}"/>
                                    </ListView.ToolTip>
                                </ListView>
                            </DockPanel>
                            <DockPanel Visibility="Collapsed" LastChildFill="True" DockPanel.Dock="Right"  Background="#FF2B2929" >
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Margin="5" Width="410">
                                    <Button Padding="10,4" Margin="10" Content="{DynamicResource UserJoin_PopOutChat}" Click="PopOutChatButton_Click" Height="26" Opacity="1" IsEnabled="False" />
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Label Padding="0" Content="{DynamicResource UserJoin_PopOutOpacity_Label}"/>
                                        <TextBlock Text="{DynamicResource UserJoin_PopOutOpacity_Value}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" HorizontalAlignment="Right" Margin="0,4,15,4">
                                    <TextBox x:Name="TextBox_BotChat" Width="150" />
                                    <Button Content="{DynamicResource Common_Send}" Margin="10,0,0,0" Padding="8,2" Click="BotChat_SendButton_Click" />
                                </StackPanel>
                                <FlowDocumentScrollViewer DockPanel.Dock="Top" BorderThickness="1,1,1,1" x:Name="FlowDoc_ChatBox" ScrollViewer.CanContentScroll="True" DataContext="{Binding Mode=OneWay, Source={StaticResource DataViews}}" Document="{Binding ChatData, Mode=OneWay, NotifyOnSourceUpdated=True}" Foreground="#FFC5C3C3" />
                            </DockPanel>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="{DynamicResource GitHub_TabHeader}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" 
                   Text="{DynamicResource GitHub_AllReleasesNote}" />

                            <TabControl>
                                <TabControl.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Setter Property="BorderBrush" Value="Black" />
                                    </Style>
                                </TabControl.Resources>

                                <TabItem Header="{DynamicResource GitHub_WikiDoc_Tab}">
                                    <DockPanel>
                                        <Label DockPanel.Dock="Top" 
                           Content="{DynamicResource GitHub_WikiDoc_Label}" />
                                        <Border>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Top" 
                                    Content="{DynamicResource Common_Reload}"  
                                    Width="59" Height="29" 
                                    Click="WebView2Reload_Click" 
                                    HorizontalAlignment="Left" />
                                                <wv2:WebView2 DataContext="" 
                                          Source="{Binding Mode=OneWay, Source={x:Static StaticLib:OptionFlags.GitHubWikiLink}}" />
                                            </DockPanel>
                                        </Border>
                                    </DockPanel>
                                </TabItem>

                                <TabItem Header="{DynamicResource GitHub_Stable_Tab}">
                                    <DockPanel>
                                        <Label DockPanel.Dock="Top" 
                           Content="{DynamicResource GitHub_Stable_Label}" />
                                        <Border>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Top" 
                                    Content="{DynamicResource Common_Reload}" 
                                    HorizontalAlignment="Left" Height="29"  
                                    Click="WebView2Reload_Click" />
                                                <wv2:WebView2 DataContext="" 
                                          Source="{Binding Mode=OneWay, Source={x:Static StaticLib:OptionFlags.GitHubStableLink}}"/>
                                            </DockPanel>
                                        </Border>
                                    </DockPanel>
                                </TabItem>

                                <TabItem Header="{DynamicResource GitHub_Latest_Tab}">
                                    <DockPanel>
                                        <Label DockPanel.Dock="Top" 
                           Content="{DynamicResource GitHub_Latest_Label}" />
                                        <Border>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Top" 
                                    Content="{DynamicResource Common_Reload}" 
                                    HorizontalAlignment="Left" Height="29"  
                                    Click="WebView2Reload_Click" />
                                                <wv2:WebView2 DataContext="" 
                                          Source="{Binding Mode=OneWay, Source={x:Static StaticLib:OptionFlags.GitHubLatestLink}}"/>
                                            </DockPanel>
                                        </Border>
                                    </DockPanel>
                                </TabItem>
                            </TabControl>
                        </DockPanel>
                    </TabItem>

                </TabControl>
            </DockPanel>
        </Grid>
    </Border>
</Window>

