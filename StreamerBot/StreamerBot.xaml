                            Click="ShoutUsers_Click"/>
                                                </StackPanel>

                                                <DataGrid x:Name="DG_User_Shoutouts" Grid.Row="1" 
                          ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_ShoutOuts_CVS}}"
