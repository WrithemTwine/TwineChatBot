                                                    <Line Fill="Black" StrokeThickness="1" Stroke="Black" X2="200" 
                              HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource Options_Welcome_Customize}"/>
                                                    <CheckBox IsChecked="{Binding WelcomeCustomMsg, Mode=TwoWay}">
                                                        <TextBlock Text="{DynamicResource Common_Enabled}"/>
                                                    </CheckBox>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Bot Management - Output -->
                                            <GroupBox Header="{DynamicResource Options_Output_Header}">
                                                <StackPanel>
                                                    <CheckBox IsChecked="{Binding MsgBotConnection}">
                                                        <TextBlock Text="{DynamicResource Options_Output_BotWelcome}"/>
                                                    </CheckBox>
                                                    <CheckBox IsChecked="{Binding MsgCommandNotFound}">
                                                        <TextBlock Text="{DynamicResource Options_Output_CommandNotFound}"/>
                                                    </CheckBox>
                                                    <CheckBox IsChecked="{Binding MsgSocialSeparate}" 
                                  ToolTip="{DynamicResource Options_Output_SocialSeparate_Tooltip}">
                                                        <TextBlock Text="{DynamicResource Options_Output_SocialSeparate}"/>
                                                    </CheckBox>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Moderate Follows -->
                                            <GroupBox Header="{DynamicResource Options_ModerateFollows_Header}">
                                                <StackPanel>
                                                    <CheckBox x:Name="CheckBox_ModFollower_BanEnable" 
                                  IsChecked="{Binding TwitchFollowerAutoBanBots}" 
                                  Checked="CheckBox_Checked_PanelVisibility" 
                                  Unchecked="CheckBox_Checked_PanelVisibility">
                                                        <StackPanel>
                                                            <TextBlock TextDecorations="Strikethrough">
                                    <Run Text="{DynamicResource Options_ModerateFollows_Enable}"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{DynamicResource Options_ModerateFollows_Note}"/>
                                                        </StackPanel>
                                                    </CheckBox>

                                                    <StackPanel x:Name="StackPanel_ModerateFollowers_Count" 
                                    Orientation="Vertical" 
                                    Visibility="Hidden" 
                                    Loaded="CheckBox_Checked_PanelVisibility">
                                                        <TextBlock Text="{DynamicResource Options_ModerateFollows_ClusterNote}"/>

                                                        <StackPanel Orientation="Horizontal">
                                                            <Label Content="{DynamicResource Options_ModerateFollows_Choose}"/>
                                                            <TextBox Width="40" Height="18" 
                                         Text="{Binding TwitchFollowerAutoBanCount, Mode=TwoWay}" 
                                         HorizontalContentAlignment="Center" 
                                         LostFocus="TextBox_Follower_LostFocus" 
                                         PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"/>
                                                        </StackPanel>

                                                        <Slider Value="{Binding TwitchFollowerAutoBanCount, Mode=TwoWay}" 
                                    Maximum="100" Minimum="1" 
                                    IsSnapToTickEnabled="True" IsSelectionRangeEnabled="True" 
                                    SelectionEnd="1" SelectionStart="1" 
                                    SmallChange="1" TickPlacement="Both" LargeChange="5"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Moderation Messages -->
                                            <GroupBox Header="{DynamicResource Options_ModerationMessages_Header}">
                                                <StackPanel>
                                                    <GroupBox Header="{DynamicResource Options_ModApprovalExpiration_Header}" 
                                  Width="Auto">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Label VerticalContentAlignment="Center" 
                                                                        Content="{DynamicResource Options_ModApprovalExpiration_Label}"/>
                                                                <Label VerticalContentAlignment="Center" 
                                                                        Content="{Binding Value, ElementName=Slider_ModApprovalTimeout}"/>
                                                            </StackPanel>
                                                            <Slider x:Name="Slider_ModApprovalTimeout" Height="40" Width="Auto" 
                                                                    AutoToolTipPlacement="TopLeft" Interval="1" 
                                                                    TickPlacement="Both"
                                                                    Value="{Binding ModeratorApprovalTimeout, Mode=TwoWay}" 
                                                                    Maximum="60" Minimum="5" SmallChange="5" 
                                                                    SelectionStart="5" SelectionEnd="60" Margin="5,0" 
                                                                    IsSnapToTickEnabled="True" 
                                                                    LostFocus="Settings_LostFocus" LargeChange="50" TickFrequency="5">
                                                                <Slider.ToolTip>
                                                                    <TextBlock Text="{DynamicResource Options_ModApprovalExpiration_Tooltip}"/>
                                                                </Slider.ToolTip>
                                                            </Slider>
                                                        </StackPanel>
                                                    </GroupBox>

                                                    <TextBlock Visibility="Collapsed">
                                                        <Run Text="{DynamicResource Options_ModerationML_Note}"/>
                                                    </TextBlock>

                                                    <CheckBox IsChecked="{Binding ModerateUserLearnMsgs}">
                                                        <TextBlock Text="{DynamicResource Options_ModerateUserLearn}"/>
                                                    </CheckBox>

                                                    <CheckBox IsChecked="{Binding ModerateUsersWarn}">
                                                        <TextBlock Text="{DynamicResource Options_ModerateUsersWarn}"/>
                                                    </CheckBox>

                                                    <CheckBox IsChecked="{Binding ModerateUsersAction}">
                                                        <TextBlock Text="{DynamicResource Options_ModerateUsersAction}"/>
                                                    </CheckBox>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Automatic Commands by Timer -->
                                            <GroupBox x:Name="GroupBox_Options_RepeatCommands" 
                                                        Header="{DynamicResource Options_RepeatCommands_Header}">
                                                <ScrollViewer 
                                                    HorizontalScrollBarVisibility="Disabled" 
                                                    VerticalScrollBarVisibility="Auto">
                                                    <StackPanel Margin="5">
                                                        <CheckBox x:Name="CheckBox_RepeatCommands_Enable" 
                                                                  IsChecked="{Binding RepeatTimerCommands, Mode=TwoWay}" 
                                                                  Checked="CheckBox_Checked_PanelVisibility" 
                                                                  Unchecked="CheckBox_Checked_PanelVisibility">
                                                            <CheckBox.ToolTip>
                                                                <TextBlock Text="{DynamicResource Options_RepeatCommands_Tooltip}"/>
                                                            </CheckBox.ToolTip>
                                                            <TextBlock Text="{DynamicResource Options_RepeatCommands_Enable}"/>
                                                        </CheckBox>

                                                        <StackPanel x:Name="StackPanel_RepeatCommands_RepeatOptions" 
                                                                    Visibility="Collapsed" 
                                                                    Loaded="CheckBox_Checked_PanelVisibility">
                                                            <CheckBox IsChecked="{Binding RepeatWhenLive, Mode=TwoWay}" 
                                          Unchecked="CheckBox_RepeatWhenLive_UnChecked">
                                                                <TextBlock Text="{DynamicResource Options_Repeat_WhenLive}"/>
                                                            </CheckBox>

                                                            <GroupBox Header="{DynamicResource Options_Repeat_Mode_Header}" Width="Auto">
                                                                <StackPanel>
                                                                    <TextBlock Text="{DynamicResource Options_Repeat_EnsureEnabled}"/>
                                                                    <RadioButton IsChecked="{Binding RepeatParallelMode, Mode=TwoWay}" 
                                                     Checked="RadioButton_RepeatCommand_ParallelMode_Checked">
                                                                        <TextBlock Text="{DynamicResource Options_Repeat_Parallel}"/>
                                                                    </RadioButton>
                                                                    <RadioButton x:Name="RadioButton_RepeatCommand_SerialMode" 
                                                     IsChecked="{Binding RepeatSerialMode, Mode=TwoWay}"
                                                     Loaded="RadioButton_RepeatCommand_SerialMode_Loaded"
                                                     Checked="RadioButton_RepeatCommand_SerialMode_Checked"
                                                     Unchecked="RadioButton_RepeatCommand_SerialMode_Unchecked">
                                                                        <TextBlock Text="{DynamicResource Options_Repeat_Serial}"/>
                                                                    </RadioButton>
                                                                </StackPanel>
                                                            </GroupBox>

                                                            <!-- Serial mode settings -->
                                                            <GroupBox x:Name="GroupBox_Options_RepeatSerialModeSettings" 
                                          Header="{DynamicResource Options_Repeat_SerialSettings_Header}" 
                                          Visibility="Collapsed" Width="Auto">
                                                                <DockPanel>
                                                                    <ListBox x:Name="ListBox_Options_RepeatSerialCommandList"
                                                 DockPanel.Dock="Right"
                                                 ItemsSource="{Binding Source={x:Static StaticLib:OptionFlags.RepeatSerialSaveData}}"
                                                 MinHeight="20">
                                                                        <ListBox.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <CheckBox IsChecked="{Binding IsSelected}">
                                                                                        <TextBlock Text="{Binding Command}" Margin="5,0,0,0"/>
                                                                                    </CheckBox>
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ListBox.ItemTemplate>
                                                                    </ListBox>

                                                                    <StackPanel DockPanel.Dock="Left">
                                                                        <StackPanel Orientation="Horizontal" >
                                                                            <TextBlock>Interval Seconds:</TextBlock>
                                                                            <TextBox Width="50" Height="20" 
     Text="{Binding RepeatSerialTime}" 
     PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll">
                                                                                <TextBox.ToolTip>
                                                                                    <TextBlock>When using Selection Order mode, specify the interval in whole seconds (yes 1, 2, 3, no 5.5) to repeat the each command.<LineBreak />600 seconds = 10 minutes, 1800 seconds = 30 minutes, 3600 seconds = 1 hour, etc.</TextBlock>
                                                                                </TextBox.ToolTip>
                                                                            </TextBox>
                                                                        </StackPanel>
                                                                        <TextBlock>Select the order of commands to repeat. The selected command list repeats indefinitely.</TextBlock>
                                                                        <StackPanel Orientation="Vertical">
                                                                            <TextBlock>Select from the following command list and click 'Add'.</TextBlock>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Button Content="Add" Margin="0,0,5,0" Click="Button_Options_RepeatSerialCommandList_Add_Click"/>
                                                                                <ComboBox Width="150" ItemsSource="{Binding CommandNoParamsCollection, Source={StaticResource DataViews}}">
                                                                                    <ComboBox.ToolTip>
                                                                                        <TextBlock>The command list items are those commands not accepting parameters. Except some default commands are marked to not accept params and can be invoked with parameters, e.g. !raid 'username'.</TextBlock>
                                                                                    </ComboBox.ToolTip>
                                                                                </ComboBox>
                                                                            </StackPanel>
                                                                            <TextBlock>(Duplicates are permitted, e.g. to repeat a command more often than others.)<LineBreak />Click the checkbox next to the command and click 'Remove' to remove from the list.</TextBlock>
                                                                            <Button Content="Remove" Width="80" Click="Button_Options_RepeatSeralCommandList_Remove_Click" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </DockPanel>
                                                            </GroupBox>

                                                            <!-- Repeat adjustment -->
                                                            <GroupBox Header="{DynamicResource Options_Repeat_Adjustment_Header}" Width="auto">
                                                                <StackPanel>
                                                                    <RadioButton x:Name="RadioButton_RepeatTimer_NoAdjustment" Margin="1,4" 
                                                     IsChecked="{Binding RepeatNoAdjustment, Mode=TwoWay}" 
                                                     Checked="CheckBox_Checked_PanelVisibility" 
                                                     Unchecked="CheckBox_Checked_PanelVisibility">
                                                                        <RadioButton.ToolTip>
                                                                            <TextBlock Text="{DynamicResource Options_Repeat_NoAdjustment_Tooltip}"/>
                                                                        </RadioButton.ToolTip>
                                                                        <TextBlock Text="{DynamicResource Options_Repeat_NoAdjustment}"/>
                                                                    </RadioButton>

                                                                    <RadioButton x:Name="RadioButton_RepeatTimer_SlowDownOption" Margin="1,4"
                                                     IsChecked="{Binding RepeatTimerComSlowdown, Mode=TwoWay}" 
                                                     Checked="CheckBox_Checked_PanelVisibility" 
                                                     Unchecked="CheckBox_Checked_PanelVisibility">
                                                                        <RadioButton.ToolTip>
                                                                            <TextBlock Text="{DynamicResource Options_Repeat_SlowDown_Tooltip}"/>
                                                                        </RadioButton.ToolTip>
                                                                        <TextBlock Text="{DynamicResource Options_Repeat_SlowDown}"/>
                                                                    </RadioButton>

                                                                    <RadioButton x:Name="RadioButton_RepeatTimer_ThresholdOption" Margin="1,4" 
                                                     IsChecked="{Binding RepeatUseThresholds, Mode=TwoWay}" 
                                                     Checked="CheckBox_Checked_PanelVisibility" 
                                                     Unchecked="CheckBox_Checked_PanelVisibility">
                                                                        <RadioButton.ToolTip>
                                                                            <TextBlock Text="{DynamicResource Options_Repeat_Threshold_Tooltip}"/>
                                                                        </RadioButton.ToolTip>
                                                                        <StackPanel Margin="0">
                                                                            <TextBlock Text="{DynamicResource Options_Repeat_Threshold_Use}"/>
                                                                        </StackPanel>
                                                                    </RadioButton>
                                                                </StackPanel>

                                                            </GroupBox>

                                                            <!-- Threshold options -->
                                                            <GroupBox x:Name="GroupBox_RepeatTimer_ThresholdOptions" 
                                          Width="auto" 
                                          Header="{DynamicResource Options_Repeat_Threshold_Header}" 
                                          Padding="0" 
                                          Loaded="CheckBox_Checked_PanelVisibility" 
                                          Visibility="Collapsed">
                                                                <StackPanel>
                                                                    <Grid>
                                                                        <StackPanel>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="40" />
                                                                                    <ColumnDefinition Width="65" />
                                                                                    <ColumnDefinition Width="65" />
                                                                                    <ColumnDefinition Width="65*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <Grid.RowDefinitions>
                                                                                    <RowDefinition Height="25*" />
                                                                                    <RowDefinition Height="25" />
                                                                                    <RowDefinition Height="25" />
                                                                                    <RowDefinition Height="25" />
                                                                                </Grid.RowDefinitions>
                                                                                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" 
                    x:Name="StackPanel_Repeat_ThresholdsOptions" Loaded="CheckBox_Checked_PanelVisibility"
                    Margin="0">
                                                                                    <CheckBox VerticalAlignment="Top" IsChecked="{Binding RepeatAboveChatCount, Mode=TwoWay}">
                                                                                        <CheckBox.ToolTip>Select to prevent messages when below chat count threshold.</CheckBox.ToolTip>
                                                                                        <TextBlock>Chat Count</TextBlock>
                                                                                    </CheckBox>
                                                                                    <Label VerticalAlignment="Top" Content="Inclusive Or"/>
                                                                                    <CheckBox VerticalAlignment="Top" IsChecked="{Binding RepeatAboveUserCount, Mode=TwoWay}">
                                                                                        <CheckBox.ToolTip>Select to prevent messages when below user count threshold.</CheckBox.ToolTip>
                                                                                        <TextBlock>User Count</TextBlock>
                                                                                    </CheckBox>
                                                                                </StackPanel>

                                                                                <Label Grid.Row="1" Grid.Column="1">
                                                                                    <TextBlock>Minutes</TextBlock>
                                                                                </Label>
                                                                                <Label Grid.Row="1" Grid.Column="2">
                                                                                    <TextBlock>Count</TextBlock>
                                                                                </Label>
                                                                                <Label Grid.Row="2" Grid.Column="0">
                                                                                    <TextBlock Padding="0">Chat</TextBlock>
                                                                                </Label>
                                                                                <Label Grid.Row="3" Grid.Column="0">
                                                                                    <TextBlock Padding="0">User</TextBlock>
                                                                                </Label>
                                                                                <TextBox Grid.Row="2" Grid.Column="1" Height="20" Width="50" 
             Text="{Binding RepeatChatMinutes}" PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"/>
                                                                                <TextBox Grid.Row="2" Grid.Column="2" Height="20" Width="50" 
             Text="{Binding RepeatChatCount}"  PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"/>
                                                                                <TextBox Grid.Row="3" Grid.Column="1" Height="20" Width="50"  
             Text="{Binding RepeatUserMinutes}"  PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"/>
                                                                                <TextBox Grid.Row="3" Grid.Column="2" Height="20" Width="50" 
             Text="{Binding RepeatUserCount}"  PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"/>
                                                                            </Grid>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </GroupBox>

                                                            <CheckBox IsChecked="{Binding RepeatLiveReset, Mode=TwoWay}">
                                                                <CheckBox.ToolTip>
                                                                    <TextBlock Text="{DynamicResource Options_Repeat_ResetOnOnline_Tooltip}"/>
                                                                </CheckBox.ToolTip>
                                                                <TextBlock Text="{DynamicResource Options_Repeat_ResetOnOnline}"/>
                                                            </CheckBox>

                                                            <CheckBox IsChecked="{Binding RepeatLiveResetShow, Mode=TwoWay}">
                                                                <CheckBox.ToolTip>
                                                                    <TextBlock Text="{DynamicResource Options_Repeat_ShowOnReset_Tooltip}"/>
                                                                </CheckBox.ToolTip>
                                                                <TextBlock Text="{DynamicResource Options_Repeat_ShowOnReset}"/>
                                                            </CheckBox>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </GroupBox>

                                            <!-- Data Management (last group in this sub-tab) -->
                                            <GroupBox x:Name="GroupBox_ManageDataOptions" 
                                                        Header="{DynamicResource Options_DataManagement_Header}">
                                                <StackPanel>
                                                    <Label>
                                                        <TextBlock Foreground="Red" 
                                           Text="{DynamicResource Options_DataManagement_UncheckWarning}"/>
                                                    </Label>

                                                    <CheckBox x:Name="CheckBox_AppData" 
                                      IsChecked="{Binding AppCurrWorkingAppData}"
                                      MouseEnter="TextBlock_MouseEnter_Visible" 
                                      MouseLeave="TextBlock_MouseEnter_Hidden">
                                                        <Border BorderThickness="1" 
                                        BorderBrush="{DynamicResource ForegroundText}">
                                                            <StackPanel>
                                                                <TextBlock TextWrapping="Wrap" 
                                                                                Text="{DynamicResource Options_AppData_Enable}"/>
                                                                <TextBlock x:Name="TextBlock_AppDataDir" 
                                                                           DataContext="{Binding Mode=OneWay, Source={StaticResource AppServices}}" 
                                                                           Text="{Binding AppDataDirectory}" 
                                                                           TextWrapping="Wrap" ToolTip="{Binding AppDataDirectory}" 
                                                                           Visibility="Hidden"/>
                                                                <TextBlock TextWrapping="Wrap" 
                                                                            Text="{DynamicResource Options_AppData_ReOpen}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </CheckBox>

                                                    <GroupBox Header="{DynamicResource Options_Data_Interlinked_Header}">
                                                        <StackPanel Orientation="Vertical">
                                                            <TextBlock ToolTip="{DynamicResource Options_Data_FollowerDependency_Tooltip}">
                                        <Run Text="{DynamicResource Options_Data_FollowerDependency}"/>
                                                            </TextBlock>

                                                            <CheckBox x:Name="CheckBox_ManageUsers" 
                                              IsChecked="{Binding ManageUsers}" 
                                              Click="CheckBox_ManageData_Click">
                                                                <TextBlock TextWrapping="Wrap" 
                                                   Text="{DynamicResource Options_Data_ManageUsers}"/>
                                                            </CheckBox>

                                                            <CheckBox x:Name="CheckBox_ManageFollowers" 
                                              IsChecked="{Binding ManageFollowers}" 
                                              Click="CheckBox_ManageData_Click">
                                                                <TextBlock TextWrapping="Wrap" 
                                                   Text="{DynamicResource Options_Data_ManageFollowers}"/>
                                                            </CheckBox>

                                                            <CheckBox x:Name="CheckBox_ManageStreamStat" 
                                              IsChecked="{Binding ManageStreamStats}" 
                                              Click="CheckBox_ManageData_Click">
                                                                <TextBlock TextWrapping="Wrap" 
                                                   Text="{DynamicResource Options_Data_ManageStreamStats}"/>
                                                            </CheckBox>
                                                        </StackPanel>
                                                    </GroupBox>

                                                    <CheckBox x:Name="CheckBox_ManageRaidData" 
                                      IsChecked="{Binding ManageRaidData}" 
                                      Click="CheckBox_ManageData_Click">
                                                        <TextBlock TextWrapping="Wrap" 
                                           Text="{DynamicResource Options_Data_ManageRaids}"/>
                                                    </CheckBox>

                                                    <CheckBox x:Name="CheckBox_ManageOutRaidData" 
                                      IsChecked="{Binding ManageOutRaidData}" 
                                      Click="CheckBox_ManageData_Click">
                                                        <TextBlock TextWrapping="Wrap" 
                                           Text="{DynamicResource Options_Data_ManageOutRaids}"/>
                                                    </CheckBox>

                                                    <CheckBox x:Name="CheckBox_ManageGiveawayUsers" 
                                      IsChecked="{Binding ManageGiveawayUsers}" 
                                      Click="CheckBox_ManageData_Click">
                                                        <TextBlock TextWrapping="Wrap" 
                                           Text="{DynamicResource Options_Data_ManageGiveaways}"/>
                                                    </CheckBox>

                                                    <CheckBox x:Name="CheckBox_ManageOverlayTicker" 
                                      IsChecked="{Binding ManageOverlayTicker}" 
                                      Click="CheckBox_ManageData_Click">
                                                        <TextBlock TextWrapping="Wrap" 
                                           Text="{DynamicResource Options_Data_ManageTicker}"/>
                                                    </CheckBox>

                                                    <Label>
                                                        <TextBlock Foreground="Red" 
                                           Text="{DynamicResource Options_DataManagement_UncheckWarning}"/>
                                                    </Label>
                                                </StackPanel>
                                            </GroupBox>

                                        </WrapPanel>
                                    </DockPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="{DynamicResource Options_Twitch_SubHeader}">
                                <ScrollViewer ScrollViewer.VerticalScrollBarVisibility="Disabled" 
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DockPanel Margin="10" HorizontalAlignment="Left" 
                   ScrollViewer.CanContentScroll="True">
                                        <WrapPanel Orientation="Vertical" DockPanel.Dock="Left">

                                            <!-- Format Bot messages -->
                                            <GroupBox Header="{DynamicResource Options_Twitch_FormatBotMessages_Header}">
                                                <StackPanel>
                                                    <Label Content="{DynamicResource Options_Twitch_FormatBotMessages_MeNote}"/>
                                                    <RadioButton x:Uid="Disabled" IsChecked="{Binding MsgNoMe, Mode=TwoWay}">
                                                        <Label Content="{DynamicResource Common_Disabled}"/>
                                                    </RadioButton>
                                                    <RadioButton IsChecked="{Binding MsgInsertMe, Mode=TwoWay}">
                                                        <RadioButton.ToolTip>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_FormatBotMessages_InsertMe_Tooltip}"/>
                                                        </RadioButton.ToolTip>
                                                        <Label Content="{DynamicResource Options_Twitch_FormatBotMessages_InsertMe}"/>
                                                    </RadioButton>
                                                    <RadioButton IsChecked="{Binding MsgPerComMe, Mode=TwoWay}">
                                                        <RadioButton.ToolTip>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_FormatBotMessages_PerCommand_Tooltip}"/>
                                                        </RadioButton.ToolTip>
                                                        <Label Content="{DynamicResource Options_Twitch_FormatBotMessages_PerCommand}"/>
                                                    </RadioButton>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Twitch - Follow Options -->
                                            <GroupBox Header="{DynamicResource Options_Twitch_FollowOptions_Header}">
                                                <StackPanel>
                                                    <CheckBox IsChecked="{Binding TwitchAddFollowersStart, Mode=TwoWay}" 
                                  ToolTip="{DynamicResource Options_Twitch_FollowOptions_AddOnStart_Tooltip}">
                                                        <TextBlock Text="{DynamicResource Options_Twitch_FollowOptions_AddOnStart}"/>
                                                    </CheckBox>
                                                    <CheckBox IsChecked="{Binding TwitchPruneNonFollowers, Mode=TwoWay}" 
                                  ToolTip="{DynamicResource Options_Twitch_FollowOptions_PruneNonFollowers_Tooltip}">
                                                        <TextBlock Text="{DynamicResource Options_Twitch_FollowOptions_PruneNonFollowers}"/>
                                                    </CheckBox>

                                                    <CheckBox x:Name="CheckBox_TwitchFollower_LimitMsgs" 
                                  IsChecked="{Binding TwitchFollowerEnableMsgLimit}" 
                                  Checked="CheckBox_Checked_PanelVisibility" 
                                  Unchecked="CheckBox_Checked_PanelVisibility">
                                                        <TextBlock Text="{DynamicResource Options_Twitch_FollowOptions_LimitMessages}"/>
                                                    </CheckBox>

                                                    <StackPanel x:Name="StackPanel_TwitchFollower_LimitMsgs_Count" 
                                    Orientation="Vertical" 
                                    Visibility="Collapsed" 
                                    Loaded="CheckBox_Checked_PanelVisibility">
                                                        <TextBlock Text="{DynamicResource Options_Twitch_FollowOptions_LimitNote}"/>

                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{DynamicResource Options_Twitch_FollowOptions_LimitChoose}"/>
                                                            <TextBox Width="40" Height="18" 
                                         Text="{Binding TwitchFollowerMsgLimit, Mode=TwoWay}" 
                                         HorizontalContentAlignment="Center" 
                                         LostFocus="TextBox_Follower_LostFocus" 
                                         PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"/>
                                                        </StackPanel>

                                                        <Slider Value="{Binding TwitchFollowerMsgLimit, Mode=TwoWay}" 
                                    Maximum="100" Minimum="1" 
                                    IsSnapToTickEnabled="True" IsSelectionRangeEnabled="True" 
                                    SelectionEnd="1" SelectionStart="1" 
                                    SmallChange="1" TickPlacement="Both" LargeChange="5"/>
                                                    </StackPanel>

                                                    <CheckBox x:Name="CheckBox_TwitchFollower_AutoRefresh" 
                                  IsChecked="{Binding TwitchFollowerAutoRefresh, Mode=TwoWay}" 
                                  Checked="CheckBox_Checked_PanelVisibility" 
                                  Unchecked="CheckBox_Checked_PanelVisibility">
                                                        <CheckBox.ToolTip>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_FollowOptions_AutoRefresh_Tooltip}"/>
                                                        </CheckBox.ToolTip>
                                                        <TextBlock Text="{DynamicResource Options_Twitch_FollowOptions_AutoRefresh}"/>
                                                    </CheckBox>

                                                    <StackPanel x:Name="StackPanel_TwitchFollows_RefreshHrs" 
                                    Orientation="Horizontal"
                                    Visibility="Hidden" 
                                    Loaded="CheckBox_Checked_PanelVisibility">
                                                        <Label Content="{DynamicResource Options_Twitch_FollowOptions_RefreshHours_Label}"/>
                                                        <ComboBox x:Name="ComboBox_TwitchFollower_RefreshHrs" Width="60" 
                                      ToolTip="{DynamicResource Options_Twitch_FollowOptions_RefreshHours_Tooltip}"
                                      SelectedValue="{Binding TwitchFollowerRefreshHrs, Mode=TwoWay}"
                                      SelectionChanged="ComboBox_TwitchFollower_RefreshHrs_SelectionChanged"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Twitch - Manage Ad Notifications -->
                                            <GroupBox Header="{DynamicResource Options_Twitch_AdNotifications_Header}">
                                                <StackPanel Orientation="Vertical">
                                                    <CheckBox x:Name="CheckBox_TwitchAdsNotify" 
                                  IsChecked="{Binding TwitchAdsNotify, Mode=TwoWay}" 
                                  Checked="CheckBox_TwitchAdsNotify_Checked">
                                                        <CheckBox.ToolTip>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_AdNotifications_Tooltip}"/>
                                                        </CheckBox.ToolTip>
                                                        <TextBlock Text="{DynamicResource Options_Twitch_AdNotifications_Enable}"/>
                                                    </CheckBox>

                                                    <!--<StackPanel Orientation="Horizontal">
                                                        <TextBox Text="{Binding TwitchAdsNotifySeconds, Mode=TwoWay}" 
                                     Width="40" Height="20" 
                                     PreviewMouseLeftButtonDown="PreviewMouseLeftButton_SelectAll"/>
                                                        <TextBlock Text="{DynamicResource Options_Twitch_AdNotifications_SecondsPre}"/>
                                                    </StackPanel>-->

                                                    <CheckBox IsChecked="{Binding TwitchAdsNotifyTimeFormatTotalTime, Mode=TwoWay}">
                                                        <CheckBox.ToolTip>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_AdNotifications_TotalTime_Tooltip}"/>
                                                        </CheckBox.ToolTip>
                                                        <TextBlock Text="{DynamicResource Options_Twitch_AdNotifications_TotalTime}"/>
                                                    </CheckBox>
                                                    <GroupBox Width="Auto" Header="{DynamicResource Options_Twitch_AdNotifications_SecondsOffsetGroupHeader}">
                                                        <StackPanel>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_AdNotifications_SecondsOffsetHeading}"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Width="100" Text="{DynamicResource Options_Twitch_AdNotifications_AdSoonSecondsOffset}"/>
                                                                <TextBox Width="40" Text="{Binding TwitchAdsAdSoonSecondsOffset}" />
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Width="100" Text="{DynamicResource Options_Twitch_AdNotifications_AdStartSecondsOffset}"/>
                                                                <TextBox Width="40" Text="{Binding TwitchAdsAdStartSecondsOffset}" />
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Width="100" Text="{DynamicResource Options_Twitch_AdNotifications_AdEndSecondsOffset}"/>
                                                                <TextBox Width="40" Text="{Binding TwitchAdsAdEndSecondsOffset}" />
                                                            </StackPanel>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_AdNotifications_SecondsOffsetNote}"/>
                                                        </StackPanel>
                                                    </GroupBox>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Twitch - Shout Out Viewers -->
                                            <GroupBox Header="{DynamicResource Options_Twitch_ShoutOut_Header}">
                                                <StackPanel>
                                                    <Label>
                                                        <TextBlock Text="{DynamicResource Options_Twitch_ShoutOut_ActiveWhenLive}"/>
                                                    </Label>
                                                    <CheckBox IsChecked="{Binding MsgAutoShout, Mode=TwoWay}">
                                                        <CheckBox.ToolTip>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_ShoutOut_Auto_Tooltip}"/>
                                                        </CheckBox.ToolTip>
                                                        <TextBlock Text="{DynamicResource Options_Twitch_ShoutOut_Auto}"/>
                                                    </CheckBox>
                                                    <CheckBox IsChecked="{Binding TwitchRaidShoutOut}">
                                                        <TextBlock Text="{DynamicResource Options_Twitch_ShoutOut_Raid}"/>
                                                    </CheckBox>
                                                    <CheckBox IsChecked="{Binding MsgSendSOToChat}">
                                                        <CheckBox.ToolTip>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_ShoutOut_SendToChat_Tooltip}"/>
                                                        </CheckBox.ToolTip>
                                                        <TextBlock Text="{DynamicResource Options_Twitch_ShoutOut_SendToChat}"/>
                                                    </CheckBox>
                                                    <CheckBox IsChecked="{Binding TwitchChannelUserShoutAPI}">
                                                        <TextBlock Text="{DynamicResource Options_Twitch_ShoutOut_API}"/>
                                                    </CheckBox>
                                                    <CheckBox IsChecked="{Binding MediaOverlayShoutoutClips}">
                                                        <StackPanel Orientation="Vertical">
                                                            <TextBlock Text="{DynamicResource Options_Twitch_ShoutOut_OverlayClips}"/>
                                                            <TextBlock Text="{DynamicResource Options_Twitch_ShoutOut_ClipSize}"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Width="50" Text="{DynamicResource Options_Twitch_ShoutOut_ClipWidth}"/>
                                                                <TextBox Text="{Binding MediaOverlayClipWidth, FallbackValue=400}" 
                                             Width="40" Height="20"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Width="50" Text="{DynamicResource Options_Twitch_ShoutOut_ClipHeight}"/>
                                                                <TextBox Text="{Binding MediaOverlayClipHeight, FallbackValue=300}" 
                                             Width="40" Height="20"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </CheckBox>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Twitch - Stream Clips -->
                                            <GroupBox Header="{DynamicResource Options_Twitch_Clips_Header}">
                                                <StackPanel>
                                                    <CheckBox IsChecked="{Binding TwitchClipPostChat, Mode=TwoWay}">
                                                        <TextBlock Text="{DynamicResource Options_Twitch_Clips_PostChat}"/>
                                                    </CheckBox>
                                                    <CheckBox IsChecked="{Binding TwitchClipPostDiscord}">
                                                        <TextBlock Text="{DynamicResource Options_Twitch_Clips_PostDiscord}"/>
                                                    </CheckBox>
                                                </StackPanel>
                                            </GroupBox>

                                            <!-- Twitch - MultiLive Options -->
                                            <GroupBox Header="{DynamicResource Options_Twitch_MultiLive_Header}">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource Options_Twitch_MultiLive_Description}"/>
                                                    <CheckBox IsChecked="{Binding TwitchMultiLiveBrowseChannel, Mode=TwoWay}">
                                                        <TextBlock Text="{DynamicResource Options_Twitch_MultiLive_OpenBrowser}"/>
                                                    </CheckBox>
                                                    <TextBlock Text="{DynamicResource Options_Twitch_MultiLive_OpenEachTime}"/>
                                                </StackPanel>
                                            </GroupBox>

                                        </WrapPanel>
                                    </DockPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="{DynamicResource Options_Database_SubHeader}">
                                <DockPanel x:Name="DockPanel_Options_DB" HorizontalAlignment="Left">
                                    <GroupBox Header="{DynamicResource Options_Database_Provider_Header}" 
                  DockPanel.Dock="Top" MinWidth="700" Width="800">
                                        <Grid ScrollViewer.VerticalScrollBarVisibility="Auto" 
                  ScrollViewer.CanContentScroll="True">
                                            <Grid.Resources>
                                                <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                                                    <Setter Property="Padding" Value="1" />
                                                    <Setter Property="VerticalAlignment" Value="Top" />
                                                    <Setter Property="TextWrapping" Value="Wrap" />
                                                    <Setter Property="Margin" Value="3" />
                                                </Style>
                                                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="VerticalAlignment" Value="Top" />
                                                </Style>
                                            </Grid.Resources>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="75" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="500*" />
                                                <ColumnDefinition Width="10" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="35" />
                                                <RowDefinition Height="3" />
                                                <RowDefinition Height="20*" />
                                                <RowDefinition Height="3" />
                                                <RowDefinition Height="20*" />
                                                <RowDefinition Height="3" />
                                                <RowDefinition Height="30*" />
                                                <RowDefinition Height="20*" />
                                                <RowDefinition Height="3" />
                                                <RowDefinition Height="20*" />
                                                <RowDefinition Height="3" />
                                                <RowDefinition Height="20*" />
                                                <RowDefinition Height="20*" />
                                                <RowDefinition Height="20*" />
                                                <RowDefinition Height="20*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" 
                           Text="{DynamicResource Options_Database_Provider_Column}"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" 
                           Text="{DynamicResource Options_Database_ConnectionVars_Column}"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" 
                           Text="{DynamicResource Options_Database_InputData_Column}"/>

                                            <Separator Grid.Row="1" Grid.ColumnSpan="3" Width="Auto"
                           VerticalContentAlignment="Bottom" />

                                            <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="{DynamicResource Options_Database_Sqlite_Label}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" 
                           Text="{DynamicResource Options_Database_ConnectString_Label}"/>
                                            <TextBox Grid.Row="2" Grid.Column="2" 
                         Text="{Binding EFCConnectStringSqlite}" />

                                            <Separator Grid.Row="3" Grid.ColumnSpan="3" Width="Auto"
                           VerticalContentAlignment="Bottom" />

                                            <TextBlock Grid.Row="4" Grid.Column="0" 
                           Text="{DynamicResource Options_Database_SqlServer_Label}"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" 
                           Text="{DynamicResource Options_Database_ConnectString_Label}"/>
                                            <TextBox Grid.Row="4" Grid.Column="2" 
                         Text="{Binding EFCConnectStringSqlServer}" />

                                            <Separator Grid.Row="5" Grid.ColumnSpan="3" Width="Auto"
                           VerticalContentAlignment="Bottom" />

                                            <TextBlock Grid.Row="6" Grid.RowSpan="2" Grid.Column="0" 
                           Text="{DynamicResource Options_Database_Cosmos_Label}"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" 
                           Text="{DynamicResource Options_Database_ConnectString_Label}"/>
                                            <TextBox Grid.Row="6" Grid.Column="2" 
                         Text="{Binding EFCConnectStringCosmos}"/>
                                            <TextBlock Grid.Row="7" Grid.Column="1" 
                           Text="{DynamicResource Options_Database_CosmosDbName_Label}"/>
                                            <TextBox Grid.Row="7" Grid.Column="2" 
                         Text="{Binding EFCDbNameCosmos}" />

                                            <Separator Grid.Row="8" Grid.ColumnSpan="3" Width="Auto" 
                           VerticalContentAlignment="Bottom" />

                                            <TextBlock Grid.Row="9" Grid.Column="0" 
                           Text="{DynamicResource Options_Database_PostgreSQL_Label}"/>
                                            <TextBlock Grid.Row="9" Grid.Column="1" 
                           Text="{DynamicResource Options_Database_ConnectString_Label}"/>
                                            <TextBox Grid.Row="9" Grid.Column="2" 
                         Text="{Binding EFCConnectStringPostgreSQL}" />

                                            <Separator Grid.Row="10" Grid.ColumnSpan="3" Width="Auto"
                           VerticalContentAlignment="Bottom" />

                                            <TextBlock Grid.Row="11" Grid.Column="0" 
                           Text="{DynamicResource Options_Database_MySql_Label}"/>
                                            <TextBlock Grid.Row="11" Grid.Column="1" 
                           Text="{DynamicResource Options_Database_ConnectString_Label}"/>
                                            <TextBox Grid.Row="11" Grid.Column="2" 
                         Text="{Binding EFCConnectStringMySql}" />

                                            <Separator Grid.Row="11" Grid.ColumnSpan="3" Width="Auto"
                           VerticalContentAlignment="Bottom" />

                                            <TextBlock Grid.Row="12" Grid.RowSpan="3" Grid.Column="0" 
                           Text="{DynamicResource Options_Database_KNet_Label}"/>
                                            <TextBlock Grid.Row="12" Grid.Column="1" 
                           Text="{DynamicResource Options_Database_KNet_Bootstrap_Label}"/>
                                            <TextBox Grid.Row="12" Grid.Column="2" 
                         Text="{Binding EFCKNetBootstrapServers}" />
                                            <TextBlock Grid.Row="13" Grid.Column="1" 
                           Text="{DynamicResource Options_Database_KNet_AppId_Label}"/>
                                            <TextBox Grid.Row="13" Grid.Column="2" 
                         Text="{Binding EFCKNetApplicationId}" />
                                            <TextBlock Grid.Row="14" Grid.Column="1" 
                           Text="{DynamicResource Options_Database_KNet_DbName_Label}"/>
                                            <TextBox Grid.Row="14" Grid.Column="2" 
                         Text="{Binding EFCDbNameKNet}" />
                                        </Grid>
                                    </GroupBox>
                                </DockPanel>
                            </TabItem>
                        </TabControl>
                    </TabItem>

                    <TabItem Header="{DynamicResource Data_TabHeader}" VerticalAlignment="Stretch" d:LayoutOverrides="Height">
                        <DockPanel>
                            <TabControl>

                                <!-- Variables sub-tab -->
                                <TabItem Header="{DynamicResource Data_Variables_SubHeader}">
                                    <DockPanel>
                                        <ListBox DockPanel.Dock="Left" 
                             DataContext="{Binding Mode=OneWay, Source={StaticResource CommandInfo}}" 
                             ItemsSource="{Binding Collection}" 
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto" 
                             ScrollViewer.CanContentScroll="True">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Parameter}" Width="150" />
                                                        <TextBlock Text="{Binding Value}" Width="650" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                </TabItem>

                                <!-- Webhooks sub-tab -->
                                <TabItem Header="{DynamicResource Data_Webhooks_SubHeader}">
                                    <DockPanel LastChildFill="True">
                                        <TextBlock IsEnabled="False" DockPanel.Dock="Top" 
                               Text="{DynamicResource Data_Webhooks_Instructions}"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                                DockPanel.Dock="Top" Margin="0,0,0,10">
                                            <Button x:Name="Button_DiscordWebhooks_Enabled" Width="80" Margin="10,0" 
                                Content="{DynamicResource Common_EnableAll}" 
                                Click="Button_DiscordWebhooks_Click" />
                                            <Button x:Name="Button_DiscordWebhooks_Disabled" Width="80" 
                                Content="{DynamicResource Common_DisableAll}" 
                                Click="Button_DiscordWebhooks_Click" />
                                        </StackPanel>

                                        <DataGrid x:Name="DG_Webhooks" DockPanel.Dock="Top"
                              ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_Webhooks_CVS}}"
                              RowDetailsTemplate="{StaticResource DG_RowDetailDT_Webhooks}"
                              CanUserDeleteRows="True" IsReadOnly="False" 
                              PreviewKeyDown="DG_PreviewKeyDown_Click"
                              ContextMenuOpening="DG_Edit_ContextMenuOpening" 
                              RowEditEnding="DataGrid_RowEditEnding">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="{DynamicResource Data_Webhooks_Id_Column}" 
                                                Binding="{Binding Id}" IsReadOnly="True" 
                                                EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                <DataGridCheckBoxColumn Header="{DynamicResource Common_Enabled}" 
                                                    Binding="{Binding IsEnabled}" />
                                                <DataGridCheckBoxColumn Header="{DynamicResource Data_Webhooks_AddEveryone_Column}" 
                                                    Binding="{Binding AddEveryone}" />
                                                <DataGridComboBoxColumn Header="{DynamicResource Data_Webhooks_Source_Column}" 
                                                    SelectedItemBinding="{Binding WebhooksSource}" 
                                                    ItemsSource="{Binding Source={StaticResource EnumWebhooksSource}}" />
                                                <DataGridComboBoxColumn Header="{DynamicResource Data_Webhooks_Kind_Column}" 
                                                    SelectedItemBinding="{Binding Kind}" 
                                                    ItemsSource="{Binding Source={StaticResource EnumWebhooksKind}}" />
                                                <DataGridTextColumn Header="{DynamicResource Data_Webhooks_Server_Column}" 
                                                Binding="{Binding Server}" Width="250" MaxWidth="250" 
                                                EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                            </DataGrid.Columns>
                                            <DataGrid.GroupStyle>
                                                <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                            </DataGrid.GroupStyle>
                                        </DataGrid>
                                    </DockPanel>
                                </TabItem>

                                <!-- Moderation sub-tab (with inner TabControl) -->
                                <TabItem Header="{DynamicResource Data_Moderation_SubHeader}">
                                    <TabControl>
                                        <!-- User Approve -->
                                        <TabItem Header="{DynamicResource Data_Moderation_UserApprove_SubHeader}" 
                             GotFocus="TabItem_ModApprove_GotFocus">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Top" 
                                       Text="{DynamicResource Data_Moderation_UserApprove_Instructions}"/>
                                                <DataGrid x:Name="DG_ModApprove" DockPanel.Dock="Top"
                                      ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_ModeratorApprove_CVS}}" 
                                      PreviewKeyDown="DG_PreviewKeyDown_Click"
                                      ContextMenuOpening="DG_Edit_ContextMenuOpening"
                                      CanUserDeleteRows="True" RowEditEnding="DataGrid_RowEditEnding">
                                                    <DataGrid.Columns>
                                                        <DataGridCheckBoxColumn Header="{DynamicResource Common_Enabled}" 
                                                            Binding="{Binding IsEnabled}" />
                                                        <DataGridComboBoxColumn Header="{DynamicResource Data_Moderation_ModActionType_Column}" 
                                                            SelectedItemBinding="{Binding ModActionType}" 
                                                            ItemsSource="{Binding Source={StaticResource EnumModActionType}}" />
                                                        <DataGridTextColumn Header="{DynamicResource Data_Moderation_ModActionName_Column}" 
                                                        Binding="{Binding ModActionName}" 
                                                        EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}" />
                                                        <DataGridComboBoxColumn Header="{DynamicResource Data_Moderation_ModPerformType_Column}" 
                                                            SelectedItemBinding="{Binding ModPerformType}" 
                                                            ItemsSource="{Binding Source={StaticResource EnumModPerformType}}" />
                                                        <DataGridTextColumn Header="{DynamicResource Data_Moderation_ModPerformAction_Column}" 
                                                        Binding="{Binding ModPerformAction}" 
                                                        EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                    </DataGrid.Columns>
                                                    <DataGrid.GroupStyle>
                                                        <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                    </DataGrid.GroupStyle>
                                                </DataGrid>
                                            </DockPanel>
                                        </TabItem>

                                        <!-- Msg Mod (Ban Reasons & Rules) -->
                                        <TabItem Header="{DynamicResource Data_Moderation_MsgMod_SubHeader}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="90" />
                                                    <RowDefinition Height="150" />
                                                    <RowDefinition Height="100*" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="300" />
                                                    <ColumnDefinition Width="700*" />
                                                    <ColumnDefinition Width="66" />
                                                    <ColumnDefinition Width="454"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.ColumnSpan="4" MinWidth="150" 
                                       Text="{DynamicResource Data_Moderation_MsgMod_Instructions}"/>

                                                <DataGrid x:Name="DG_Mod_BanReasons" Grid.Row="1" Grid.Column="0" Margin="5,5,5,5" 
                                      ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_BanReasons_CVS}}" 
                                      PreviewKeyDown="DG_PreviewKeyDown_Click"
                                      CanUserDeleteRows="False" CanUserAddRows="False" 
                                      HorizontalScrollBarVisibility="Disabled" 
                                      VerticalScrollBarVisibility="Disabled" 
                                      RowEditEnding="DataGrid_RowEditEnding" 
                                      ContextMenuOpening="DG_Edit_ContextMenuOpening">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="{DynamicResource Data_Mod_Id_Column}" 
                                                        Binding="{Binding Id}" 
                                                        EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridComboBoxColumn Header="{DynamicResource Data_Mod_MsgType_Column}"
                                                            ItemsSource="{Binding Source={StaticResource EnumMsgTypes}}"
                                                            SelectedItemBinding="{Binding MsgType}" />
                                                        <DataGridComboBoxColumn Header="{DynamicResource Data_Mod_BanReason_Column}" 
                                                            ItemsSource="{Binding Source={StaticResource EnumBanReason}}" 
                                                            SelectedItemBinding="{Binding BanReason}" />
                                                    </DataGrid.Columns>
                                                    <DataGrid.GroupStyle>
                                                        <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                    </DataGrid.GroupStyle>
                                                </DataGrid>

                                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="5,5,5,5" 
                                       Text="{DynamicResource Data_Mod_TimeoutNote}"/>

                                                <DataGrid x:Name="DG_Mod_BanRules" Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" Margin="5" 
                                      ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_BanRules_CVS}}" 
                                      PreviewKeyDown="DG_PreviewKeyDown_Click"
                                      CanUserDeleteRows="True" 
                                      ContextMenuOpening="DG_Edit_ContextMenuOpening" 
                                      RowEditEnding="DataGrid_RowEditEnding" 
                                      Grid.ColumnSpan="2">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="{DynamicResource Data_Mod_Id_Column}" 
                                                        Binding="{Binding Id}" 
                                                        EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridComboBoxColumn Header="{DynamicResource Data_Mod_ModAction_Column}" 
                                                            ItemsSource="{Binding Source={StaticResource EnumModActions}}" 
                                                            SelectedItemBinding="{Binding ModAction}" />
                                                        <DataGridComboBoxColumn Header="{DynamicResource Data_Mod_MsgType_Column}" 
                                                            ItemsSource="{Binding Source={StaticResource EnumMsgTypes}}" 
                                                            SelectedItemBinding="{Binding MsgType}" />
                                                        <DataGridTextColumn Header="{DynamicResource Data_Mod_TimeoutSecs_Column}" 
                                                        Binding="{Binding TimeoutSeconds, Converter={StaticResource TimeoutSecConvert}}" 
                                                        EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridComboBoxColumn Header="{DynamicResource Data_Mod_ViewerTypes_Column}" 
                                                            ItemsSource="{Binding Source={StaticResource EnumViewerTypes}}" 
                                                            SelectedItemBinding="{Binding ViewerTypes}" />
                                                    </DataGrid.Columns>
                                                    <DataGrid.GroupStyle>
                                                        <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                    </DataGrid.GroupStyle>
                                                </DataGrid>

                                                <DataGrid x:Name="DG_Mod_LearnMsgs" Grid.Row="2" Grid.ColumnSpan="2" Grid.Column="0" 
                                      Margin="5,5,5,5" 
                                      ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_LearnMsgs_CVS}}" 
                                      PreviewKeyDown="DG_PreviewKeyDown_Click"
                                      ContextMenu="{StaticResource DataGrid_LearnMsgsContextMenu}"
                                      IsReadOnly="False" 
                                      RowEditEnding="DataGrid_RowEditEnding">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="{DynamicResource Data_Mod_Id_Column}" 
                                                        Binding="{Binding Id}" 
                                                        EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        <DataGridComboBoxColumn Header="{DynamicResource Data_Mod_MsgType_Column}" 
                                                            ItemsSource="{Binding Source={StaticResource EnumMsgTypes}}" 
                                                            SelectedItemBinding="{Binding MsgType}" />
                                                        <DataGridTextColumn Header="{DynamicResource Data_Mod_LearningMessage_Column}" 
                                                        Width="650" Binding="{Binding TeachingMsg}" 
                                                        EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                    </DataGrid.Columns>
                                                    <DataGrid.GroupStyle>
                                                        <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                    </DataGrid.GroupStyle>
                                                </DataGrid>
                                            </Grid>
                                        </TabItem>
                                    </TabControl>
                                </TabItem>

                                <!-- User Data sub-tab -->
                                <TabItem Header="{DynamicResource Data_UserData_SubHeader}" x:Name="TabItem_Users">
                                    <TabControl TabStripPlacement="Left">
                                        <TabItem Header="{DynamicResource Data_UserData_UserFollow_SubHeader}">
                                            <Grid x:Name="Grid_UserData_UserFollow">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition MinWidth="150" Width="200*" />
                                                    <ColumnDefinition Width="5" />
                                                    <ColumnDefinition MinWidth="200" Width="200*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Visibility="Collapsed" 
                           DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" 
                           Text="{Binding GridTabifyUserFollowWidth}" />

                                                <TabControl x:Name="TabControl_UD_UF_Grid_Tab" 
                            Visibility="Collapsed" Grid.ColumnSpan="3">
                                                    <TabItem Header="{DynamicResource Data_UserData_Users_Tab}" 
                             x:Name="TabItem_UD_UF_Grid_Users" />
                                                    <TabItem Header="{DynamicResource Data_UserData_Followers_Tab}" 
                             x:Name="TabItem_UD_UF_Grid_Followers" />
                                                </TabControl>

                                                <DockPanel x:Name="DockPanel_UserData_Users" Grid.Row="0" Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                                                        <Label Content="{DynamicResource Data_UserData_Users_Label}"/>
                                                        <Button x:Name="Button_ClearNonFollowers" 
                                Content="{DynamicResource Data_UserData_ClearNonFollowers}" 
                                Height="20" Width="130" 
                                Margin="70,0,15,0" 
                                Click="Button_ClearNonFollowers_Click">
                                                            <Button.ToolTip>
                                                                <TextBlock Text="{DynamicResource Data_UserData_ClearNonFollowers_Tooltip}"/>
                                                            </Button.ToolTip>
                                                        </Button>
                                                        <Button x:Name="Button_ClearWatchTime" 
                                Content="{DynamicResource Data_UserData_ResetWatchTime}" 
                                Height="20" Width="120" 
                                Click="Button_ClearWatchTime_Click" 
                                Margin="15,0,15,0" />
                                                    </StackPanel>

                                                    <DataGrid x:Name="DG_Users" 
                              ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_Users_CVS}}" 
                              ContextMenuOpening="DG_Edit_ContextMenuOpening" 
                              IsReadOnly="False" CanUserDeleteRows="True" 
                              PreviewKeyDown="DG_PreviewKeyDown_Click"
                              RowDetailsTemplate="{StaticResource DG_RowDetailDT_Users}" 
                              RowEditEnding="DataGrid_RowEditEnding">
                                                        <DataGrid.Columns>
                                                            <DataGridComboBoxColumn Header="{DynamicResource Data_UserData_Platform_Column}" 
                                                    SelectedValueBinding="{Binding Platform}" 
                                                    ItemsSource="{Binding Source={StaticResource EnumPlatform}}" />
                                                            <DataGridTextColumn Header="{DynamicResource Data_UserData_UserId_Column}" 
                                                Binding="{Binding UserId}" 
                                                EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                            <DataGridTextColumn Header="{DynamicResource Data_UserData_UserName_Column}" 
                                                Binding="{Binding UserName}" 
                                                EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                            <DataGridCheckBoxColumn Header="{DynamicResource Data_UserData_Follower_Column}" 
                                                    Binding="{Binding Follower.IsFollower}" />

                                                            <DataGridTemplateColumn Header="{DynamicResource Data_UserData_LastSeen_Column}" 
                                                    CellTemplate="{Binding Source={StaticResource DateLastSeenTemplate}}" 
                                                    SortMemberPath="LastDateSeen" 
                                                    SortDirection="Descending" />
                                                            <DataGridTextColumn Header="{DynamicResource Data_UserData_WatchTime_Column}" 
                                                Binding="{Binding UserStats.WatchTime}" 
                                                EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                        </DataGrid.Columns>
                                                        <DataGrid.GroupStyle>
                                                            <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                        </DataGrid.GroupStyle>
                                                    </DataGrid>
                                                </DockPanel>

                                                <DockPanel x:Name="DockPanel_UserData_Followers" Grid.Row="0" Grid.Column="2">
                                                    <Label Content="{DynamicResource Data_UserData_Followers_Label}" 
                           DockPanel.Dock="Top" />
                                                    <DataGrid x:Name="DG_Followers" 
                              ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_Follows_CVS}}" 
                              PreviewKeyDown="DG_PreviewKeyDown_Click"
                              ContextMenuOpening="DG_Edit_ContextMenuOpening" 
                              CanUserAddRows="False" CanUserDeleteRows="True" 
                              IsReadOnly="True" 
                              RowDetailsTemplate="{StaticResource DG_RowDetailDT_Followers}" 
                              RowEditEnding="DataGrid_RowEditEnding">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="{DynamicResource Data_UserData_UserId_Column}" 
                                                Binding="{Binding UserId}" 
                                                SortMemberPath="UserId" 
                                                EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                            <DataGridTextColumn Header="{DynamicResource Data_UserData_UserName_Column}" 
                                                Binding="{Binding User.UserName}" 
                                                EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"/>
                                                            <DataGridTemplateColumn Header="{DynamicResource Data_UserData_FollowedDate_Column}" 
                                                    CellTemplate="{Binding Source={StaticResource DateFollowedTemplate}}"  
                                                    SortMemberPath="FollowedDate" 
                                                    SortDirection="Descending" />
                                                            <DataGridTemplateColumn Header="{DynamicResource Data_UserData_StatusChanged_Column}" 
                                                    CellTemplate="{Binding Source={StaticResource DateStatusChangedTemplate}}" 
                                                    SortMemberPath="StatusChangeDate" 
                                                    SortDirection="Descending" />
                                                            <DataGridComboBoxColumn Header="{DynamicResource Data_UserData_Platform_Column}" 
                                                    SelectedItemBinding="{Binding Platform}" 
                                                    ItemsSource="{Binding Source={StaticResource EnumPlatform}}" />
                                                        </DataGrid.Columns>
                                                        <DataGrid.GroupStyle>
                                                            <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                        </DataGrid.GroupStyle>
                                                    </DataGrid>
                                                </DockPanel>
                                            </Grid>
                                        </TabItem>

                                        <!-- Old Follows -->
                                        <TabItem Header="{DynamicResource Data_OldFollows_SubHeader}">
                                            <DockPanel>
                                                <DataGrid x:Name="DG_OldFollowUsers" 
                          ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_OldFollowUsers_CVS}}" 
                          ContextMenuOpening="DG_Edit_ContextMenuOpening" 
                          CanUserAddRows="False" CanUserDeleteRows="True" 
                          PreviewKeyDown="DG_PreviewKeyDown_Click"
                          AutoGenerateColumns="True" 
                          RowEditEnding="DataGrid_RowEditEnding">
                                                    <DataGrid.GroupStyle>
                                                        <StaticResource ResourceKey="DataGrid_GroupStyle" />
                                                    </DataGrid.GroupStyle>
                                                </DataGrid>
                                            </DockPanel>
                                        </TabItem>

                                        <!-- Auto-SO -->
                                        <TabItem Header="{DynamicResource Data_AutoSO_SubHeader}">
