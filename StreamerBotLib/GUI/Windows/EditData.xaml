<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="clr-namespace:StreamerBotLib.Models"
    x:Class="StreamerBotLib.GUI.Windows.EditData"
    mc:Ignorable="d"
    Title="Edit DataGrid" 
    Height="250" Width="450" MinHeight="250" 
    MaxHeight="800" MaxWidth="550" 
    SnapsToDevicePixels="True" 
    Closing="Window_Closing" 
    SizeToContent="WidthAndHeight" 
    UseLayoutRounding="True" 
    Topmost="True">
    <Window.Resources>
        <DataTemplate x:Key="CategoryCheckBox" DataType="ListBox">
            <CheckBox Content="{Binding Item1}" IsChecked="{Binding Item2}" Checked="EditData_Category_Checked" Unchecked="EditData_Category_Checked" />
        </DataTemplate>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top">
            <TextBlock TextWrapping="Wrap" Margin="5,0,0,0">
                - This feature is currently in testing. Please report any complications.<LineBreak />
                - Ensure dates are formatted properly, the way presented.<LineBreak />
                - A red box means the date or item isn't formatted properly.<LineBreak />
                - When specifying media files, *DO NOT* exceed 2GB limit per file.<LineBreak />
                - The data field name on the left shows character count for text fields. The Twitch chat bot will split messages exceeding the 500 character limit per message.
            </TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" HorizontalAlignment="Center" Margin="0,8">
            <Button Content="Ok" Margin="20,0" Click="Button_OKClick" Padding="10,2" />
            <Button x:Name="Button_Cancel" Content="Cancel" Click="CancelButton_Click" Padding="10,2" Visibility="Collapsed" />
        </StackPanel>
        <ListBox x:Name="ListBox_DataList" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0,5,0,10" />
    </DockPanel>
</Window>
