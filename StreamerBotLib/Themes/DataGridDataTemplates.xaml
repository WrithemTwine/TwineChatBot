<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:SqlModels="clr-namespace:StreamerBotLib.DataSQL.Models"
    xmlns:GUI="clr-namespace:StreamerBotLib.GUI"
    xmlns:SqlModelConverters="clr-namespace:StreamerBotLib.DataSQL.Models.Converters"
    xmlns:Converter="clr-namespace:StreamerBotLib.Models.Converters"
    xmlns:Models="clr-namespace:StreamerBotLib.Models"
    xmlns:StaticLib="clr-namespace:StreamerBotLib.Static"
    xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
    mc:Ignorable="d">

    <SqlModelConverters:IntConvert x:Name="IntConverter" x:Key="IntConverter" />
    <SqlModelConverters:TimeoutSecondsConverter x:Name="TimeoutSecConvert" x:Key="TimeoutSecConvert" />
    <StaticLib:MsgVarHelp x:Name="CommandInfo" x:Key="CommandInfo" />
    <Converter:ConvertCategory x:Name="ConvertCategory" x:Key="ConvertCategory" />
    <Converter:EditConvertCategory x:Name="EditConvertCategory" x:Key="EditConvertCategory" />
    <Converter:IndexConverter x:Name="IndexConverter" x:Key="IndexConverter" />
    <Converter:StatValueConverter x:Name="AppDataConverter" x:Key="AppDataConverter" />
 
    <GroupStyle x:Key="DataGrid_GroupStyle">
        <GroupStyle.HeaderTemplate>
            <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="2,5">
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="{Binding Name}" />
                    <TextBlock Text=" - " />
                    <TextBlock Text="{Binding ItemCount}" />
                    <TextBlock Text=" item(s)" />
                </StackPanel>
            </DataTemplate>
        </GroupStyle.HeaderTemplate>
        <GroupStyle.Panel>
            <ItemsPanelTemplate>
                <DataGridRowsPresenter />
            </ItemsPanelTemplate>
        </GroupStyle.Panel>
    </GroupStyle>

    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="AlternationCount" Value="1" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundText}" />
        <Setter Property="Background" Value="{DynamicResource PartBackground}" />
        <Setter Property="RowBackground" Value="{DynamicResource DataGridBackground}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource DataGridAlternateColor}"/>
        <Setter Property="CanUserAddRows" Value="False" />

        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="Background" Value="{DynamicResource DataGridColumnHeaderBackground}" />
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundText}" />
                    <Setter Property="Padding" Value="8,0" />
                </Style>
            </Setter.Value>
        </Setter>

        <Setter Property="RowHeaderStyle">
            <Setter.Value>
                <Style TargetType="{x:Type DataGridRowHeader}">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowHeaderBackground}" />
                    <Setter Property="Width" Value="5" />
                </Style>
            </Setter.Value>
        </Setter>

    </Style>


    <DataTemplate x:Key="CategoryDataTemplate">
        <StackPanel>
            <TextBlock Text="{Binding Category, Mode=TwoWay, Converter={StaticResource ConvertCategory}}" TextWrapping="Wrap" Width="250" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EditCategoryDataTemplate">
        <StackPanel>
            <ListBox
                x:Name="ComboBox_EditCategoryDataTemplate" 
                MinHeight="50" MaxHeight="200"
                ItemsSource="{Binding Category, Mode=TwoWay, Converter={StaticResource EditConvertCategory}}" />
        </StackPanel>
    </DataTemplate>

    <!--#region DataGrid DateTime templates -->
    <DataTemplate x:Key="DateFirstSeenTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding FirstDateSeen, StringFormat={}{0:F}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateCurrentLoginTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding CurrLoginDate, StringFormat={}{0:F}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateLastSeenTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding LastDateSeen, StringFormat={}{0:g}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateFollowedTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding FollowedDate, StringFormat={}{0:g}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateStatusChangedTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding StatusChangeDate, StringFormat={}{0:g}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateGiveawayTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding DateTime, StringFormat={}{0:f}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EditDateGiveawayTemplate">
        <StackPanel>
            <TextBox Text="{Binding DateTime}" ToolTip="Input date and time in the provided format." />
            <!--<DatePicker SelectedDate="{Binding DateTime}" />-->
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateInRaidTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding RaidDate, StringFormat={}{0:f}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EditInRaidTemplate">
        <StackPanel>
            <TextBox Text="{Binding RaidDate}" ToolTip="Input date and time in the provided format." />
            <!--<DatePicker SelectedDate="{Binding RaidDate}" />-->
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateOutRaidTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding RaidDate, StringFormat={}{0:f}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EditOutRaidTemplate">
        <StackPanel>
            <TextBox Text="{Binding RaidDate}" ToolTip="Input date and time in the provided format." />
            <!--<DatePicker SelectedDate="{Binding RaidDate}" />-->
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateClipCreatedTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:g}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateStreamStartTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding StreamStart, StringFormat={}{0:f}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EditStreamStartTemplate">
        <StackPanel>
            <TextBox Text="{Binding StreamStart}" ToolTip="Input date and time in the provided format." />
            <!--<DatePicker SelectedDate="{Binding StreamStart}" />-->
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateStreamEndTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding StreamEnd, StringFormat={}{0:f}}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EditStreamEndTemplate">
        <StackPanel>
            <TextBox Text="{Binding StreamEnd}" ToolTip="Input date and time in the provided format." />
            <!--<DatePicker SelectedDate="{Binding StreamEnd}" />-->
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="StreamDurationTemplate">
        <TextBlock Text="{Binding Duration, StringFormat={}{0:g}}" />
    </DataTemplate>

    <DataTemplate x:Key="DateLiveTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding LiveDate}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EditLiveDateTemplate">
        <StackPanel>
            <TextBox Text="{Binding LiveDate}" ToolTip="Input date and time in the provided format." />
            <!--<DatePicker SelectedDate="{Binding LiveDate}" />-->
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="DateThroughTemplate">
        <StackPanel>
            <Border BorderThickness="1">
                <TextBlock Text="{Binding ThroughDate}" />
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="EditThroughDateTemplate">
        <StackPanel>
            <TextBox Text="{Binding ThroughDate}" ToolTip="Input date and time in the provided format." />
            <!--<DatePicker SelectedDate="{Binding ThroughDate}" />-->
        </StackPanel>
    </DataTemplate>

    <!--#endregion-->

    <!--#region DataGrid RowDetail DataTemplates -->

    <DataTemplate x:Key="DG_RowDetailDT_Clips">
        <Border BorderThickness="2">
            <StackPanel Orientation="Vertical">
                <StackPanel.Resources>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Margin" Value="0,3" />
                        <Setter Property="Orientation" Value="Horizontal" />
                    </Style>
                </StackPanel.Resources>
                <StackPanel>
                    <TextBlock>Category:</TextBlock>
                    <TextBlock Text="{Binding CategoryId}" />
                    <TextBlock> -</TextBlock>
                    <TextBlock Text="{Binding CategoryList.Category}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock>Language:</TextBlock>
                    <TextBlock Text="{Binding Language}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock>Title:</TextBlock>
                    <TextBlock Text="{Binding Title}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock>URL:</TextBlock>
                    <TextBlock Text="{Binding Url}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="DG_RowDetailDT_Commands">
        <Border BorderThickness="2">
            <DockPanel>
                <DockPanel.Resources>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Margin" Value="0,3" />
                        <Setter Property="Orientation" Value="Horizontal" />
                    </Style>
                    <Style TargetType="{x:Type TextBox}">
                        <Setter Property="MinWidth" Value="75" />
                        <Setter Property="Foreground" Value="{StaticResource ForegroundText}" />
                    </Style>
                </DockPanel.Resources>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock>Usage:</TextBlock>
                    <TextBlock Background="{StaticResource LightBackground}" Text="{Binding Usage}" TextWrapping="Wrap" />
                    <TextBlock>Allow Parameter: </TextBlock>
                    <CheckBox IsChecked="{Binding AllowParam}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock>Send Message Count:</TextBlock>
                    <TextBox Text="{Binding SendMsgCount, Converter={StaticResource IntConverter}}" />
                    <TextBlock>Message:</TextBlock>
                    <TextBox Text="{Binding Message}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock>Lookup Data: </TextBlock>
                    <CheckBox IsChecked="{Binding LookupData}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Width="100">Lookup Table: </TextBlock>
                    <TextBox Text="{Binding Table}" />
                    <TextBlock Width="100">Key Field: </TextBlock>
                    <TextBox Text="{Binding KeyField}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Width="100">Data Field: </TextBlock>
                    <TextBox Text="{Binding DataField}" />
                    <TextBlock Width="100">Currency Field: </TextBlock>
                    <TextBox Text="{Binding CurrencyField}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock>Action: </TextBlock>
                    <ComboBox ItemsSource="{Binding Source={StaticResource EnumCommandAction}}" SelectedItem="{Binding Action}"/>
                    <TextBlock>Sort: </TextBlock>
                    <ComboBox ItemsSource="{Binding Source={StaticResource EnumCommandSort}}" SelectedItem="{Binding Sort}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock>Select Top N Records: </TextBlock>
                    <TextBox Text="{Binding Top, Converter={StaticResource IntConverter}}" />
                    <TextBlock>Record Units (e.g. chat,chats): </TextBlock>
                    <TextBox Text="{Binding Unit}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="DG_RowDetailDT_Followers">
        <Border BorderThickness="2">
            <StackPanel Orientation="Vertical">
                <StackPanel.Resources>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Margin" Value="0,3" />
                        <Setter Property="Orientation" Value="Horizontal" />
                    </Style>
                </StackPanel.Resources>
                <StackPanel>
                    <TextBlock>Category when Followed:</TextBlock>
                    <TextBlock Text="{Binding Category}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock>Followed Date:</TextBlock>
                    <TextBlock Text="{Binding FollowedDate, StringFormat={}{0:F}}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock>Status Changed Date:</TextBlock>
                    <TextBlock Text="{Binding StatusChangeDate, StringFormat={}{0:F}}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="DG_RowDetailDT_OverlayServices">
        <Border BorderThickness="2">
            <DockPanel>
                <DockPanel.Resources>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Margin" Value="0,3" />
                        <Setter Property="Orientation" Value="Horizontal" />
                    </Style>
                </DockPanel.Resources>
                <StackPanel>
                    <TextBlock>Message:</TextBlock>
                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="DG_RowDetailDT_Webhooks">
        <Border BorderThickness="1">
            <DockPanel>
                <DockPanel.Resources>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Margin" Value="0,3" />
                        <Setter Property="Orientation" Value="Horizontal" />
                    </Style>
                </DockPanel.Resources>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock>Server NickName:</TextBlock>
                    <TextBox Text="{Binding Server}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock>Webhook URL:</TextBlock>
                    <TextBox TextWrapping="Wrap" Text="{Binding Webhook}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="DG_RowDetailDT_MultiChannelNames">
        <Border BorderThickness="1">
            <StackPanel Orientation="Vertical">
                <StackPanel.Resources>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Margin" Value="0,3" />
                        <Setter Property="Orientation" Value="Horizontal" />
                    </Style>
                </StackPanel.Resources>
                <TextBlock>Summary Data, if available:<LineBreak />
                (use archive tab to compact daily data)</TextBlock>
                <StackPanel>
                    <TextBlock>Through Date:</TextBlock>
                    <TextBlock Text="{Binding MultiSummaryLiveStreams.ThroughDate, FallbackValue=1/1/1900}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock>Number of Streams:</TextBlock>
                    <TextBlock Text="{Binding MultiSummaryLiveStreams.StreamCount, FallbackValue=0, StringFormat={}{0:N0}}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="DG_RowDetailDT_Users">
        <Border BorderThickness="1">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0">First Date seen:</TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FirstDateSeen, StringFormat={}{0:g}}" />

                <TextBlock Grid.Row="1" Grid.Column="0">Followed Date:</TextBlock>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Follower.FollowedDate, FallbackValue=\&quot;Not a Follower\&quot;, StringFormat=\{0:g\}}" />

                <TextBlock Grid.Row="3" Grid.Column="0">Current Login:</TextBlock>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CurrLoginDate, StringFormat={}{0:F}}" />
                <TextBlock Grid.Row="4" VerticalAlignment="Bottom" >Activity Stats:</TextBlock>
                <TextBlock Grid.Row="5" Grid.Column="0">Commands called:</TextBlock>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding UserStats.CallCommands, StringFormat={}{0:N0}}" />
                <TextBlock Grid.Row="6" Grid.Column="0">Chats:</TextBlock>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding UserStats.ChannelChat, StringFormat={}{0:N0}}" />
                <TextBlock Grid.Row="7" Grid.Column="0">Clips created:</TextBlock>
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding UserStats.ClipsCreated, StringFormat={}{0:N0}}" />
                <TextBlock Grid.Row="8" Grid.Column="0">Channel Point Rewards:</TextBlock>
                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding UserStats.RewardRedeems, StringFormat={}{0:N0}}" />

            </Grid>
        </Border>
    </DataTemplate>

    <!--#endregion-->

    <!--#region DataGrid SelectionViews for Sorting & Grouping table rows -->

    <GUI:GUIDataManagerViews x:Name="DataViews" x:Key="DataViews" />

    <CollectionViewSource x:Key="DG_BanReasons_CVS" Source="{Binding BanReasons, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_BanRules_CVS" Source="{Binding BanRules, Source={StaticResource DataViews}}">
        <CollectionViewSource.GroupDescriptions>
            <PropertyGroupDescription PropertyName="ViewerTypes" />
        </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_CategoryList_CVS" Source="{Binding CategoryList, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_ChannelEvents_CVS" Source="{Binding ChannelEvents, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="Name" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_Clips_CVS" Source="{Binding Clips, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="CategoryList.Category" Direction="Ascending" />
        </CollectionViewSource.SortDescriptions>
        <CollectionViewSource.GroupDescriptions>
            <PropertyGroupDescription PropertyName="CategoryList.Category" />
        </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_Commands_CVS" Source="{Binding Commands, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="CmdName"/>
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_CommandsUser_CVS" Source="{Binding CommandsUser, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="CmdName"/>
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_Currency_CVS" Source="{Binding Currency, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="User.UserName" />
        </CollectionViewSource.SortDescriptions>
        <CollectionViewSource.GroupDescriptions>
            <PropertyGroupDescription PropertyName="CurrencyName" />
        </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_CurrencyType_CVS" Source="{Binding CurrencyType, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_CustomWelcome_CVS" Source="{Binding CustomWelcome, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="User.UserName" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>

    <CollectionViewSource x:Key="DG_Follows_CVS" Source="{Binding Followers, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="FollowedDate" Direction="Descending" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>

    <CollectionViewSource x:Key="DG_GameDeadCounter_CVS" Source="{Binding GameDeadCounter, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_GiveawayUserData_CVS" Source="{Binding GiveawayUserData, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="DateTime" Direction="Descending" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_InRaidData_CVS" Source="{Binding InRaidData, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="RaidDate" Direction="Descending" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_LearnMsgs_CVS" Source="{Binding LearnMsgs, Source={StaticResource DataViews}}">
        <CollectionViewSource.GroupDescriptions>
            <PropertyGroupDescription PropertyName="MsgType" />
        </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_ModeratorApprove_CVS" Source="{Binding ModeratorApprove, Source={StaticResource DataViews}}" >
        <CollectionViewSource.GroupDescriptions>
            <PropertyGroupDescription PropertyName="ModActionType" />
        </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_MultiChannels_CVS" Source="{Binding MultiChannels, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="UserName" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_MultiLiveStreams_CVS" Source="{Binding MultiLiveStreams, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="LiveDate" Direction="Descending" />
            <scm:SortDescription PropertyName="MultiChannels.UserName" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>

    <CollectionViewSource x:Key="DG_MultiWebhooks_CVS" Source="{Binding MultiWebhooks, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="Server" />
            <scm:SortDescription PropertyName="Kind" />
        </CollectionViewSource.SortDescriptions>
        <CollectionViewSource.GroupDescriptions>
            <PropertyGroupDescription PropertyName="Kind" />
        </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_MultiSummaryLiveStreams_CVS" Source="{Binding MultiSummaryLiveStreams, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_OldFollowUsers_CVS" Source="{Binding OldFollowUsers, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_OutRaidData_CVS" Source="{Binding OutRaidData, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="RaidDate" Direction="Descending" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_OverlayServices_CVS" Source="{Binding OverlayServices, Source={StaticResource DataViews}}">
        <CollectionViewSource.GroupDescriptions>
            <PropertyGroupDescription PropertyName="OverlayType" />
        </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_OverlayTicker_CVS" Source="{Binding OverlayTicker, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_Quotes_CVS" Source="{Binding Quotes, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_ShoutOuts_CVS" Source="{Binding ShoutOuts, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_StreamStats_CVS" Source="{Binding StreamStats, Source={StaticResource DataViews}}">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="StreamStart" Direction="Descending" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_Users_CVS" Source="{Binding Users, Source={StaticResource DataViews}}" IsLiveSortingRequested="True">
        <CollectionViewSource.SortDescriptions>
            <scm:SortDescription PropertyName="LastDateSeen" Direction="Descending" />
            <scm:SortDescription PropertyName="UserName" />
        </CollectionViewSource.SortDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="DG_UserStats_CVS" Source="{Binding UserStats, Source={StaticResource DataViews}}" />
    <CollectionViewSource x:Key="DG_Webhooks_CVS" Source="{Binding Webhooks, Source={StaticResource DataViews}}" />

    <!--#endregion-->



</ResourceDictionary>