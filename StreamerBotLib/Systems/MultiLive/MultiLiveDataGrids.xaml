<Page x:Class="StreamerBotLib.Systems.MultiLive.MultiLiveDataGrids"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:s="clr-namespace:StreamerBotLib.Properties"
      xmlns:Enums="clr-namespace:StreamerBotLib.Models.Enums;assembly=StreamerBotLib"
      xmlns:core="clr-namespace:System;assembly=mscorlib" 
      xmlns:M="clr_namespace:StreamerBotLib.Models" 
      xmlns:gui="clr-namespace:StreamerBotLib.GUI;assembly=StreamerBotLib" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MultiLiveDataGrids" SnapsToDevicePixels="True" UseLayoutRounding="True" 
      DataContext="{DynamicResource DataViews}"
      Background="{DynamicResource FullBackground}"
      >
    <Page.Resources>
        <ContextMenu x:Key="DataGrid_Multi_ContextMenu" Name="DataGrid_Multi_ContextMenu">
            <MenuItem x:Name="DataGridContextMenu_Multi_AddItem"  Header="Add New Row" Click="MenuItem_AddClick" />
            <MenuItem x:Name="DataGridContextMenu_Multi_EditItem" Header="Edit Selected Row" />
            <MenuItem x:Name="DataGridContextMenu_Multi_DeleteItems" Header="Delete Selected Row(s)" 
                      ToolTip="Delete 1 or more rows, not for preset tables. No warning messages."/>
        </ContextMenu>
        <ObjectDataProvider x:Key="PlatformEnums" MethodName="GetValues" ObjectType="{x:Type core:Enum}" >
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="Enums:Platform" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Page.Resources>

    <Grid x:Name="Grid_MultiUserLiveMonitor" DataContext="{Binding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="60*" />
            <RowDefinition Height="150*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="298*" />
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="180*"  />
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="320*"/>
        </Grid.ColumnDefinitions>

        <TextBlock TextWrapping="Wrap" Grid.Row="0" Grid.ColumnSpan="2" Padding="3">
            <TextBlock.ToolTip>The Twitch documentation for checking user streams might say 100 at a 
                time, but the TwitchLib library will check as many as you want, it does this by cycling 
                through the stream list 100 users at a time until all are checked!</TextBlock.ToolTip>
            <TextBlock.Text>Use this tab to set up which channels to watch for going live and where 
                to post messages. Currently only Discord.</TextBlock.Text>
        </TextBlock>
        <StackPanel Grid.Row="0" Grid.Column="3" Grid.ColumnSpan="2" >
            <TextBlock TextWrapping="Wrap" Text="Message for Live Notification:" />
            <TextBox x:Name="TB_LiveMsg" VerticalContentAlignment="Top" 
                                 DataContext="{Binding Mode=OneWay, Source={x:Static s:Settings.Default}}" Text="{Binding MsgLive}" 
                                 TextAlignment="Left" TextWrapping="Wrap" LostFocus="Settings_LostFocus" >
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="#user" Click="MenuItem_Click" />
                        <MenuItem Header="#category" Click="MenuItem_Click" />
                        <MenuItem Header="#title" Click="MenuItem_Click" />
                        <MenuItem Header="#url" Click="MenuItem_Click" />
                    </ContextMenu>
                </TextBox.ContextMenu>
                <TextBox.ToolTip>
                    <TextBlock><Run Text="Use these tags within the message and it'll be replaced before sending the posted live message."/><LineBreak /><Run Text="Available by right-click menu - insert at cursor."/><LineBreak /><Run Text="&quot;#user&quot; - channel name of the user"/><LineBreak /><Run Text="&quot;#category&quot; - the category of the stream"/><LineBreak /><Run Text="&quot;#title&quot; - the title of the stream when it goes live"/><LineBreak /><Run Text="&quot;#url&quot; - to send someone to the Twitch channel, it's already prepared &quot; twitch.tv/user &quot;"/><LineBreak /><LineBreak /><Run Text="Example: @everyone, #user is now live streaming #category - #title! Come join and say hi at: #url"/></TextBlock>
                </TextBox.ToolTip>
            </TextBox>
        </StackPanel>

        <DataGrid x:Name="DG_Multi_WebHooks" Grid.Row="1" Grid.Column="0"
                  ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_MultiWebhooks_CVS}}"
                  RowDetailsTemplate="{StaticResource DG_RowDetailDT_MultiWebhooks}" 
                  ContextMenu="{StaticResource DataGrid_Multi_ContextMenu}"
                  ContextMenuOpening="DG_MultiEdit_ContextMenuOpening" 
                  CanUserDeleteRows="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" IsReadOnly="True" />
                <DataGridCheckBoxColumn Header="IsEnabled" Binding="{Binding IsEnabled}" />
                <DataGridCheckBoxColumn Header="Add @Everyone" Binding="{Binding AddEveryone}" />
                <DataGridComboBoxColumn Header="Webhook Source" SelectedItemBinding="{Binding WebhooksSource}" ItemsSource="{Binding Source={StaticResource EnumWebhooksSource}}" />
                <DataGridComboBoxColumn Header="Kind" SelectedItemBinding="{Binding Kind}" ItemsSource="{Binding Source={StaticResource EnumWebhooksKind}}" />
                <DataGridTextColumn Header="Server" Binding="{Binding Server}" Width="80" MaxWidth="120" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" >
            <Label DockPanel.Dock="Top">Monitored Channels</Label>

            <TabControl>
                <TabItem Header="Channels">
                    <DataGrid x:Name="DG_Multi_ChannelNames" DockPanel.Dock="Top"
                  ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_MultiChannels_CVS}}" 
                      RowDetailsTemplate="{StaticResource DG_RowDetailDT_MultiChannelNames}" 
                      ContextMenu="{StaticResource DataGrid_Multi_ContextMenu}"
                      ContextMenuOpening="DG_MultiEdit_ContextMenuOpening" 
                      CanUserDeleteRows="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="User Id" Binding="{Binding UserId}" />
                            <DataGridTextColumn Header="User Name" Binding="{Binding UserName}" />
                            <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Lookup User">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Use this form to lookup a user Id if you only know the channel name." />
                        <GroupBox Header="User" Width="Auto">
                            <StackPanel>
                                <TextBlock Padding="4" Margin="3">Platform:</TextBlock>
                                <ComboBox x:Name="ComboBox_MultiUsers_LookupUser_Platform" Padding="4" Margin="3"  ItemsSource="{Binding Source={StaticResource PlatformEnums}}" />
                                <TextBlock Padding="4" Margin="3">UserName:</TextBlock>
                                <TextBox x:Name="TextBox_MultiUsers_LookupUser_UserName" Padding="4" Margin="3" />
                                <Button x:Name="Button_MultiUser_FindUserId" Content="Find User Id" Width="100" Margin="3"
                                        Click="Button_MultiUser_FindUserId_Click" />
                                <TextBlock Padding="4" Margin="3">UserId:</TextBlock>
                                <TextBox x:Name="TextBox_MultiUsers_LookupUser_UserId" Padding="4" Margin="3" />
                                <Button x:Name="Button_MultiUser_PostNewMultiUser" Content="Add Channel" Width="100" Margin="3" IsEnabled="False" Click="Button_MultiUser_PostNewMultiUser_Click" />
                            </StackPanel>
                        </GroupBox>
                    </DockPanel>
                </TabItem>
            </TabControl>

        </DockPanel>

        <TabControl Grid.Column="4" Grid.Row="1" Grid.RowSpan="2" >
            <TabItem Header="Daily Data" x:Name="TabItem_DailyData">
                <DataGrid x:Name="DG_Multi_LiveStreamStats"
                          ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_MultiLiveStreams_CVS}}" 
                          ContextMenu="{StaticResource DataGrid_Multi_ContextMenu}"
                          CanUserDeleteRows="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User Id" Binding="{Binding UserId}" />
                        <DataGridTextColumn Header="User Name" Binding="{Binding MultiChannels.UserName}" />
                        <DataGridTemplateColumn Header="Live Date" CellTemplate="{StaticResource DateLiveTemplate}" CellEditingTemplate="{StaticResource EditLiveDateTemplate}" SortMemberPath="LiveDate" />
                        <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Summary" x:Name="TabItem_SummaryDailyData">
                <DataGrid x:Name="DG_Multi_SummaryLiveStreamStats" 
                          ItemsSource="{Binding Mode=OneWay, Source={StaticResource DG_MultiSummaryLiveStreams_CVS}}" 
                          ContextMenu="{StaticResource DataGrid_Multi_ContextMenu}"
                          CanUserDeleteRows="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User Id" Binding="{Binding MultiChannels.UserId}" />
                        <DataGridTextColumn Header="User Name" Binding="{Binding MultiChannels.UserName}" />
                        <DataGridTemplateColumn Header="Live Date" CellTemplate="{StaticResource DateThroughTemplate}" CellEditingTemplate="{StaticResource EditThroughDateTemplate}" SortMemberPath="ThroughDate" />
                        <DataGridTextColumn Header="Streams" Binding="{Binding StreamCount, StringFormat={}{0:N0}}" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Archive">
                <DockPanel>
                    <DockPanel.Resources>
                    </DockPanel.Resources>
                    <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="10">
                        The Multi-Live procedure generates a lot of data. This tab allows summarizing and collapses 
                        the data based on notification date.
                    </TextBlock>
                    <GroupBox Header="Live Date Archive Form">
                        <StackPanel>
                            <TextBlock Padding="5">1) Select Date and how many stream notifications to archive.</TextBlock>
                            <TextBlock Visibility="Visible" Foreground="Red" TextWrapping="Wrap">
                                Clicking the pull-down box loads available selection 
                                data. Large sets may take a while. Please wait.
                            </TextBlock>
                            <ComboBox x:Name="ComboBox_SummarizeLive_List" Height="32"
                                      MaxDropDownHeight="400" VerticalAlignment="Top" VerticalContentAlignment="Center" 
                                      ItemsSource="{Binding CleanupList, Mode=OneWay}" DropDownOpened="ComboBox_DropDownOpened" 
                                      IsReadOnly="True" IsSynchronizedWithCurrentItem="True" 
                                      SelectionChanged="ComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:Name="SumDataTemplate" DataType="M:ArchiveMultiStream">
                                        <StackPanel Orientation="Horizontal">
                                            <Label Content="{Binding ThroughDate}" />
                                            <Label Content="{Binding StreamCount}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Padding="5" TextWrapping="Wrap">
                                2) Click 'Summarize' to archive the total live notifications count prior
                                to and including the selected date. These notifications per channel are added to
                                the Summary table, either as a new row or added to the existing row. The last date in the
                                archive operation, per channel, is also saved.
                            </TextBlock>
                            <Button x:Name="Button_StartSummarizingLiveData" IsEnabled="False" Width="75" Content="Summarize" Click="Button_StartSummarizingLiveData_Click" />
                        </StackPanel>
                    </GroupBox>
                </DockPanel>
            </TabItem>
        </TabControl>

        <DockPanel x:Name="Panel_BotActivity" Grid.Row="2" Grid.Column="0" Visibility="Visible">
            <Label DockPanel.Dock="Top" Content="Log of Bot Activity:" />
            <ListBox DockPanel.Dock="Bottom" x:Name="TB_BotActivityLog" Margin="5" VerticalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto" ItemsSource="{Binding MultiLiveStatusLog, Mode=OneWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</Page>
